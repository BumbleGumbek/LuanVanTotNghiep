<!DOCTYPE html>
<html lang="en">
<head>
    <base href="/" />
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Luna Jewelry - Trang sức cao cấp</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/flaticon.css">
    <link rel="stylesheet" href="/css/barfiller.css">
    <link rel="stylesheet" href="/css/magnific-popup.css">
    <link rel="stylesheet" href="/css/elegant-icons.css">
    <link rel="stylesheet" href="/css/nice-select.css">
    <link rel="stylesheet" href="/css/owl.carousel.min.css">
    <link rel="stylesheet" href="/css/slicknav.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/product-detail.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        .cart-count {
            position: absolute;
            top: -10px;
            right: -10px;
            background: #ff0000;
            color: #fff;
            font-size: 10px;
            font-weight: 700;
            height: 18px;
            width: 18px;
            line-height: 18px;
            text-align: center;
            border-radius: 50%;
            display: inline-block;
        }
        .header__top__right__cart a {
            position: relative;
        }
        .heart-active {
            color: #ff0000 !important;
        }
        .product__item__pic__hover {
            position: absolute;
            left: 0;
            bottom: -50px;
            width: 100%;
            text-align: center;
            -webkit-transition: all, 0.5s;
            -o-transition: all, 0.5s;
            transition: all, 0.5s;
        }
        .product__item:hover .product__item__pic__hover {
            bottom: 20px;
        }
        .product__item__pic__hover li {
            list-style: none;
            display: inline-block;
            margin-right: 6px;
        }
        .product__item__pic__hover li:last-child {
            margin-right: 0;
        }
        .product__item__pic__hover li a {
            font-size: 18px;
            color: #111111;
            height: 45px;
            width: 45px;
            line-height: 48px;
            text-align: center;

            display: block;
            -webkit-transition: all, 0.3s;
            -o-transition: all, 0.3s;
            transition: all, 0.3s;
        }
        .product__item__pic__hover li a:hover {
            background: #ff0000;
            border-color: #ff0000;
        }
        .product__item__pic__hover li a:hover i {
            color: #ffffff;
        }
    </style>
</head>

<body>
<div id="preloder">
    <div class="loader"></div>
</div>

<header class="header">
    <div class="header__top">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="header__top__inner">
                        <div class="header__top__left">
                            <ul>
                                <li>VND<span class="arrow_carrot-down"></span>
                                    <ul>
                                        <li>VND</li>
                                        <li>USD</li>
                                    </ul>
                                </li>
                                <li>ENG<span class="arrow_carrot-down" ></span>
                                    <ul>
                                        <li>VN</li>
                                        <li>ENG</li>
                                    </ul>
                                </li>
                                {{#if user}}
                                    <li>
                                        <a href="">
                                            Xin chào, {{user.firstName}}
                                            <span class="arrow_carrot-down"></span>
                                        </a>
                                        <ul>
                                            <li>
                                                <a href="/profile">
                                                    Hồ sơ của tôi
                                                </a>
                                            </li>
                                            <li>
                                                <a href="/my-orders">
                                                    Đơn hàng của tôi
                                                </a>
                                            </li>
                                            <li>
                                                <a href="/logout">
                                                    Đăng xuất
                                                </a>
                                            </li>
                                        </ul>
                                    </li>
                                {{else}}
                                    <li><a href="/login">Đăng nhập</a></li>
                                {{/if}}
                            </ul>
                        </div>
                        <div class="header__logo">
                            <a href="/">
                                <img src="/img/logo.jpg" alt="">
                            </a>
                        </div>
                        <div class="header__top__right">
                            <div class="header__search">
                                <form action="/search" method="GET" class="header__search__form">
                                    <input type="text" name="keyword" placeholder="Tìm kiếm trang sức...">
                                    <button type="submit">
                                        <img src="/img/icon/search.png" alt="">
                                    </button>
                                </form>
                            </div>

                            <div class="header__top__right__links">
                                <a href="/wishlist">
                                    <img src="/img/icon/heart.png" alt="">
                                </a>
                            </div>

                            <div class="header__top__right__cart">
                                <a href="/shopping-cart">
                                    <img src="/img/icon/cart.png" alt="">
                                    {{#if totalQty}}
                                        <span class="cart-count">{{totalQty}}</span>
                                    {{/if}}
                                </a>
                                <div class="cart__price">
                                    Giỏ hàng:
                                    <span>
                                        {{formatCurrency totalPrice}} VND
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <nav class="header__menu mobile-menu">
                    <ul>
                        <li class="{{#if (eq activePage 'home')}}active{{/if}}">
                            <a href="/">Trang chủ</a>
                        </li>
                        <li class="{{#if (eq activePage 'jewelry')}}active{{/if}}">
                            <a href="/jewelry">Trang sức</a>
                            <ul class="dropdown">
                                <li><a href="/jewelry?cat=rings">Nhẫn</a></li>
                                <li><a href="/jewelry?cat=necklaces">Dây chuyền</a></li>
                                <li><a href="/jewelry?cat=bracelets">Vòng tay</a></li>
                                <li><a href="/jewelry?cat=earrings">Bông tai</a></li>
                                <li><a href="/jewelry?cat=watches">Đồng hồ</a></li>
                            </ul>
                        </li>
                        <li class="{{#if (eq activePage 'collections')}}active{{/if}}">
                            <a href="/collections">Bộ sưu tập</a>
                            <ul class="dropdown">
                                <li><a href="/collections?col=new">Hàng mới về</a></li>
                                <li><a href="/collections?col=bestseller">Bán chạy nhất</a></li>
                                <li><a href="/collections?col=sale">Khuyến mãi</a></li>
                                <li><a href="/collections?col=gift">Quà tặng</a></li>
                            </ul>
                        </li>
                        <li class="{{#if (eq activePage 'about')}}active{{/if}}"><a href="/about">Giới thiệu</a></li>
                        <li class="{{#if (eq activePage 'contact')}}active{{/if}}"><a href="/contact">Liên hệ</a></li>
                        {{#if isAdmin}}
                            <li><a href="/admin">Quản trị</a></li>
                        {{/if}}
                        {{#if isWarehouse}}
                            <li><a href="/admin">Quản trị</a></li>
                        {{/if}}
                        {{#if isSupplier}}
                            <li><a href="/admin">Quản trị</a></li>
                        {{/if}}
                        {{#if isStoreManager}}
                            <li><a href="/admin">Quản trị</a></li>
                        {{/if}}
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</header>

{{{body}}}

<footer class="footer set-bg" data-setbg="/img/footer-bg.jpg">
    <div class="container">
        <div class="row">
            <div class="col-lg-4">
                <div class="footer__widget">
                    <h6>GIỜ HOẠT ĐỘNG</h6>
                    <ul>
                        <li>Thứ Hai - Thứ Sáu: 08:00 - 20:30</li>
                        <li>Thứ Bảy: 10:00 - 16:30</li>
                        <li>Chủ Nhật: 10:00 - 16:30</li>
                    </ul>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="footer__about">
                    <div class="footer__logo">
                        <a href="/"><img src="/img/footer-logo.png" alt=""></a>
                    </div>
                    <p>Trang sức thanh lịch dành cho phụ nữ hiện đại.</p>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="footer__newslatter">
                    <h6>Đăng ký nhận tin</h6>
                    <p>Nhận các bộ sưu tập và ưu đãi mới nhất từ chúng tôi.</p>
                </div>
            </div>
        </div>
    </div>
</footer>

<script src="/js/jquery-3.3.1.min.js"></script>
<script src="/js/bootstrap.min.js"></script>
<script src="/js/jquery.nice-select.min.js"></script>
<script src="/js/jquery.barfiller.js"></script>
<script src="/js/jquery.magnific-popup.min.js"></script>
<script src="/js/jquery.slicknav.js"></script>
<script src="/js/owl.carousel.min.js"></script>
<script src="/js/jquery.nicescroll.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>