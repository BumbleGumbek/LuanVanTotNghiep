<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-12">
            <div class="row align-items-center mb-4">
                <div class="col">
                    <h2>Create Import Request</h2>
                    <p class="text-muted">Create a request to order inventory variants from suppliers.</p>
                </div>
                <div class="col-auto">
                    <a href="/admin/import-request" class="btn btn-secondary px-4">
                        <i class="fe fe-arrow-left mr-1"></i> Back to List
                    </a>
                </div>
            </div>

            {{#if success_message}}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    {{success_message}}
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
            {{/if}}
            {{#if error_message}}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    {{error_message}}
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
            {{/if}}

            <form action="/admin/import-request/create" method="POST" id="create-request-form">
                <div class="row">
                    <!-- Left Column: Core Request Settings -->
                    <div class="col-md-4">
                        <div class="card shadow mb-4">
                            <div class="card-header">
                                <strong class="card-title"><i class="fe fe-file-text mr-2"></i>Request Info</strong>
                            </div>
                            <div class="card-body">
                                <div class="form-group mb-3">
                                    <label class="form-label font-weight-bold">Supplier <span class="text-danger">*</span></label>
                                    <select name="supplier" id="supplier" class="form-control custom-select" required>
                                        <option value="" disabled selected>-- Select Supplier --</option>
                                        {{#each plainSuppliers}}
                                            <option value="{{this._idStr}}">{{this.name}}</option>
                                        {{/each}}
                                    </select>
                                </div>
                                <div class="form-group mb-0">
                                    <label class="form-label font-weight-bold">Note / Reason</label>
                                    <textarea name="note" class="form-control" rows="4" placeholder="Describe the reason or add instructions..."></textarea>
                                </div>
                            </div>
                        </div>

                        <!-- General Submission Card -->
                        <div class="card shadow">
                            <div class="card-body">
                                <button type="submit" class="btn btn-primary btn-lg btn-block shadow-sm font-weight-bold py-3">
                                    <i class="fe fe-check mr-2"></i> Submit Import Request
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column: Products & Variants Table -->
                    <div class="col-md-8">
                        <div class="card shadow mb-4">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <strong class="card-title"><i class="fe fe-package mr-2"></i>Requested Items</strong>
                                <button type="button" class="btn btn-sm btn-success px-3" id="add-item-btn">
                                    <i class="fe fe-plus mr-1"></i> Add Item
                                </button>
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-bordered mb-0" id="items-table" style="min-width: 600px;">
                                        <thead class="bg-light">
                                            <tr>
                                                <th style="width: 45%;">Product <span class="text-danger">*</span></th>
                                                <th style="width: 20%;">Size <span class="text-danger">*</span></th>
                                                <th style="width: 15%;">Current Stock</th>
                                                <th style="width: 15%;">Quantity <span class="text-danger">*</span></th>
                                                <th style="width: 5%;" class="text-center">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody id="items-tbody">
                                            <!-- Dynamic rows injected here -->
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    window.productsData = {{{productsJson}}};
    window.selectedProductsData = {{{selectedProductsJson}}};
</script>
<script src="/js/import-request-create.js"></script>