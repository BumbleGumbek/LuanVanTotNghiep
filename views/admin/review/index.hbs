<div class="container-fluid">
    <div class="row align-items-center mb-4">
        <div class="col">
            <h2 class="h3 mb-1 page-title">Review Management</h2>
            <p class="text-muted">Monitor and moderate customer reviews and ratings for your products.</p>
        </div>
    </div>

    <!-- Alert Messages -->
    {{#if success_message}}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{success_message}}
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    {{/if}}
    {{#if error_message}}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            {{error_message}}
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    {{/if}}

    <!-- Statistics Panel -->
    <div class="row mb-4">
        <!-- Total Reviews Card -->
        <div class="col-md-4">
            <div class="card shadow border-0 text-center h-100 bg-primary text-white d-flex align-items-center justify-content-center" style="min-height: 250px;">
                <div class="card-body py-4">
                    <i class="bi bi-chat-left-text-fill display-3 opacity-75"></i>
                    <h3 class="mt-3 text-white h5">Total Reviews</h3>
                    <div class="display-3 font-weight-bold">{{totalReviews}}</div>
                    <p class="mb-0 text-white-50">Customer feedback submitted</p>
                </div>
            </div>
        </div>

        <!-- Rating breakdown -->
        <div class="col-md-8">
            <div class="card shadow border-0 h-100">
                <div class="card-header border-0 bg-transparent pt-4">
                    <h5 class="card-title mb-0"><i class="bi bi-bar-chart-fill text-primary mr-2"></i>Rating Breakdown</h5>
                </div>
                <div class="card-body">
                    {{#each ratingStats}}
                        <div class="d-flex align-items-center mb-3">
                            <span class="mr-2 font-weight-bold text-secondary" style="width: 50px;">{{rating}} <i class="bi bi-star-fill text-warning"></i></span>
                            <div class="progress flex-grow-1" style="height: 12px; border-radius: 6px;">
                                {{#if (eq rating 5)}}
                                    <div class="progress-bar bg-success" role="progressbar" style="width: {{percentage}}%; border-radius: 6px;" aria-valuenow="{{percentage}}" aria-valuemin="0" aria-valuemax="100"></div>
                                {{/if}}
                                {{#if (eq rating 4)}}
                                    <div class="progress-bar bg-info" role="progressbar" style="width: {{percentage}}%; border-radius: 6px;" aria-valuenow="{{percentage}}" aria-valuemin="0" aria-valuemax="100"></div>
                                {{/if}}
                                {{#if (eq rating 3)}}
                                    <div class="progress-bar bg-warning" role="progressbar" style="width: {{percentage}}%; border-radius: 6px;" aria-valuenow="{{percentage}}" aria-valuemin="0" aria-valuemax="100"></div>
                                {{/if}}
                                {{#if (eq rating 2)}}
                                    <div class="progress-bar bg-orange" role="progressbar" style="width: {{percentage}}%; border-radius: 6px; background-color: #fd7e14;" aria-valuenow="{{percentage}}" aria-valuemin="0" aria-valuemax="100"></div>
                                {{/if}}
                                {{#if (eq rating 1)}}
                                    <div class="progress-bar bg-danger" role="progressbar" style="width: {{percentage}}%; border-radius: 6px;" aria-valuenow="{{percentage}}" aria-valuemin="0" aria-valuemax="100"></div>
                                {{/if}}
                            </div>
                            <span class="ml-3 text-muted" style="width: 80px;">{{count}} ({{percentage}}%)</span>
                        </div>
                    {{/each}}
                </div>
            </div>
        </div>
    </div>

    <!-- Reviews Table -->
    <div class="card shadow border-0">
        <div class="card-header border-0 bg-transparent pt-4">
            <h5 class="card-title mb-0"><i class="bi bi-list-stars text-primary mr-2"></i>Reviews List</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted uppercase font-weight-bold" style="font-size: 0.85rem;">
                        <tr>
                            <th class="pl-4">Product Name</th>
                            <th>Customer Name</th>
                            <th>Rating</th>
                            <th style="width: 40%;">Comment</th>
                            <th>Created Date</th>
                            <th class="text-right pr-4">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each reviews}}
                            <tr>
                                <td class="pl-4 font-weight-bold">
                                    {{#if product}}
                                        {{product.name}}
                                    {{else}}
                                        <span class="text-muted italic">Unknown Product</span>
                                    {{/if}}
                                </td>
                                <td>
                                    {{#if user}}
                                        {{user.firstName}} {{user.lastName}}
                                        <br>
                                        <small class="text-muted">{{user.email}}</small>
                                    {{else}}
                                        <span class="text-muted italic">Unknown Customer</span>
                                    {{/if}}
                                </td>
                                <td>
                                    <div class="text-warning">
                                        {{#if (eq rating 5)}}
                                            <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i>
                                        {{/if}}
                                        {{#if (eq rating 4)}}
                                            <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star"></i>
                                        {{/if}}
                                        {{#if (eq rating 3)}}
                                            <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star"></i><i class="bi bi-star"></i>
                                        {{/if}}
                                        {{#if (eq rating 2)}}
                                            <i class="bi bi-star-fill"></i><i class="bi bi-star-fill"></i><i class="bi bi-star"></i><i class="bi bi-star"></i><i class="bi bi-star"></i>
                                        {{/if}}
                                        {{#if (eq rating 1)}}
                                            <i class="bi bi-star-fill"></i><i class="bi bi-star"></i><i class="bi bi-star"></i><i class="bi bi-star"></i><i class="bi bi-star"></i>
                                        {{/if}}
                                    </div>
                                    <small class="text-muted">{{rating}} / 5</small>
                                </td>
                                <td>
                                    <p class="mb-0 text-secondary text-wrap" style="max-height: 80px; overflow-y: auto;">
                                        {{comment}}
                                    </p>
                                </td>
                                <td class="text-muted">{{formatDate createdAt}}</td>
                                <td class="text-right pr-4">
                                    <form action="/admin/review/{{_id}}?_method=DELETE" method="POST" onsubmit="return confirm('Are you sure you want to delete this review?')" style="display:inline;">
                                        <button type="submit" class="btn btn-link p-0 text-danger" title="Delete Review">
                                            <i class="bi bi-trash3" style="font-size: 1.1rem;"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {{else}}
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-chat-left-quote display-4 d-block mb-3 opacity-50"></i>
                                    No customer reviews available yet.
                                </td>
                            </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
