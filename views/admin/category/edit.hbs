<div class="card shadow">
    <div class="card-body">
        <form action="/admin/category/edit/{{category._id}}?_method=PUT" method="POST">
            <div class="mb-3">
                <label class="form-label">
                    Category Title
                </label>
                <input type="text" name="title" class="form-control" value="{{category.title}}" required>
            </div>
            <div class="mb-3">
                <label class="form-label">
                    Category Description
                </label>
                <textarea name="description" class="form-control" rows="4">{{category.description}}</textarea>
            </div>
            <div class="mb-4">
                <label class="form-label">
                    Status
                </label>
                <select name="status"
                        class="form-control">
                    <option value="true"
                        {{#if category.status}}
                            selected
                        {{/if}}>
                        True
                    </option>
                    <option value="false"
                        {{#unless category.status}}
                            selected
                        {{/unless}}>
                        False
                    </option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary">
                Update Category
            </button>
        </form>
    </div>
</div>