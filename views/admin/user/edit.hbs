<div class="card shadow">
    <div class="card-body">
        <form action="/users/edit/{{user._id}}" method="POST">
            <div class="mb-3">
                <label class="form-label">Tên</label>
                <input type="text" name="firstName" value="{{user.firstName}}" class="form-control">
            </div>
            <div class="mb-3">
                <label class="form-label">Họ</label>
                <input type="text" name="lastName" value="{{user.lastName}}" class="form-control">
            </div>
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="email" value="{{user.email}}" class="form-control">
            </div>
            <div class="mb-3">
                <label class="form-label">Mật khẩu</label>
                <input type="password" name="password" placeholder="Để trống nếu giữ nguyên mật khẩu cũ" class="form-control">
            </div>
            <div class="mb-3">
                <label class="form-label">Vai trò</label>
                <select name="role" id="roleSelect" class="form-control">
                    <option value="customer"
                        {{#if (eq user.role 'customer')}}
                            selected
                        {{/if}}>
                        Khách hàng
                    </option>

                    <option value="admin"
                        {{#if (eq user.role 'admin')}}
                            selected
                        {{/if}}>
                        Quản trị viên
                    </option>

                    <option value="warehouse"
                        {{#if (eq user.role 'warehouse')}}
                            selected
                        {{/if}}>
                        Thủ kho
                    </option>

                    <option value="supplier"
                        {{#if (eq user.role 'supplier')}}
                            selected
                        {{/if}}>
                        Nhà cung cấp
                    </option>

                    <option value="store_manager"
                        {{#if (eq user.role 'store_manager')}}
                            selected
                        {{/if}}>
                        Quản lý cửa hàng
                    </option>

                </select>
            </div>

            <div class="mb-3" id="supplierSelectGroup" style="display: none;">
                <label class="form-label">Đối tác cung cấp</label>
                <select name="supplierId" class="form-control">
                    <option value="" disabled selected>-- Chọn nhà cung cấp --</option>
                    {{#each plainSupplier}}
                        <option value="{{this._idStr}}"
                            {{#if (eq this._idStr ../selectedSupplierId)}}
                                selected
                            {{/if}}>
                            {{this.name}}
                        </option>
                    {{/each}}
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">
                    Trạng thái
                </label>
                <select name="status"
                        class="form-control">
                    <option value="true"
                        {{#if user.status}}
                            selected
                        {{/if}}>
                        Hoạt động
                    </option>
                    <option value="false"
                        {{#unless user.status}}
                            selected
                        {{/unless}}>
                        Khóa
                    </option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary">
                Cập nhật tài khoản
            </button>
        </form>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const roleSelect = document.getElementById('roleSelect');
        const supplierSelectGroup = document.getElementById('supplierSelectGroup');

        function toggleSupplierSelect(roleValue) {
            if (roleValue === 'supplier') {
                supplierSelectGroup.style.display = 'block';
            } else {
                supplierSelectGroup.style.display = 'none';
            }
        }

        if (roleSelect && supplierSelectGroup) {
            // Check initial state
            toggleSupplierSelect(roleSelect.value);

            // Listen for changes
            roleSelect.addEventListener('change', function() {
                toggleSupplierSelect(this.value);
            });
        }
    });
</script>
