<div class="card shadow">
    <div class="card-body">

        <div class="d-flex align-items-center mb-3">
            <div>
                <h5 class="card-title mb-1">
                    Bảng tài khoản quản trị
                </h5>
                <p class="card-text mb-0">
                    Quản lý tất cả tài khoản quản trị viên tại đây.
                </p>
                <p class="card-text mt-2 font-weight-bold">
                    Tổng số lượng tài khoản quản trị : {{plainUser.length}}
                </p>
            </div>
            <div class="flex-grow-1 d-flex justify-content-center">
                <form action="/users/admins" method="GET" class="form-inline searchform text-muted">
                    <input
                            class="form-control mr-sm-2 bg-transparent border-0 pl-4 text-muted"
                            type="search"
                            name="keyword"
                            value="{{keyword}}"
                            placeholder="Tìm kiếm quản trị viên..."
                            aria-label="Search"
                            style="width: 300px;">
                </form>
            </div>
            <a href="/users/create" class="btn btn-primary">
                Thêm quản trị viên
            </a>
        </div>

        <table class="table table-hover align-middle">
            <thead>
            <tr>
                <th>#</th>
                <th>Họ và tên</th>
                <th>Email</th>
                <th>Vai trò</th>
                <th>Trạng thái</th>
                <th>Sửa</th>
                <th>Xóa</th>
            </tr>
            </thead>
            <tbody>
            {{#each plainUser}}
                <tr>
                    <td>{{add @index 1}}</td>
                    <td>{{firstName}} {{lastName}}</td>
                    <td>{{email}}</td>
                    <td>
                        <span class="badge {{#if (eq role 'admin')}}badge-danger{{else}}badge-primary{{/if}}">
                            Quản trị viên
                        </span>
                    </td>
                    <td>
                        {{#if status}}
                            <span class="text-success"><i class="bi bi-check-circle-fill"></i> Hoạt động</span>
                        {{else}}
                            <span class="text-danger"><i class="bi bi-x-circle-fill"></i> Khóa</span>
                        {{/if}}
                    </td>
                    <td>
                        <a href="/users/edit/{{_id}}">
                            <i class="bi bi-pencil text-warning"></i>
                        </a>
                    </td>
                    <td>
                        <a href="/users/delete/{{_id}}"
                           onclick="return confirm('Xác nhận xóa tài khoản quản trị này?')">
                            <i class="bi bi-trash text-danger"></i>
                        </a>
                    </td>
                </tr>
            {{/each}}
            </tbody>
        </table>
    </div>
</div>