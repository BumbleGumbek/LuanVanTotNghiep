<div class="card shadow">
    <div class="card-body">

        <div class="d-flex align-items-center mb-3">
            <div>
                <h5 class="card-title mb-1">
                    Admin Table
                </h5>
                <p class="card-text mb-0">
                    Manage all registered admins here.
                </p>
                <p class="card-text mt-2 font-weight-bold">
                    Total number of admins : {{plainUser.length}}
                </p>
            </div>
            <div class="flex-grow-1 d-flex justify-content-center">
                <form action="/users/admins" method="GET" class="form-inline searchform text-muted">
                    <input
                            class="form-control mr-sm-2 bg-transparent border-0 pl-4 text-muted"
                            type="search"
                            name="keyword"
                            value="{{keyword}}"
                            placeholder="Search admins..."
                            aria-label="Search"
                            style="width: 300px;">
                </form>
            </div>
            <a href="/users/create" class="btn btn-primary">
                Add Admin
            </a>
        </div>

        <table class="table table-hover align-middle">
            <thead>
            <tr>
                <th>#</th>
                <th>Full Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Status</th>
                <th>Edit</th>
                <th>Delete</th>
            </tr>
            </thead>
            <tbody>
            {{#each plainUser}}
                <tr>
                    <td>{{add @index 1}}</td>
                    <td>{{firstName}} {{lastName}}</td>
                    <td>{{email}}</td>
                    <td>
                        <span class="badge {{#if (eq role 'admin')}}badge-danger{{else}}badge-primary{{/if}}">
                            {{role}}
                        </span>
                    </td>
                    <td>
                        {{#if status}}
                            <span class="text-success"><i class="bi bi-check-circle-fill"></i> Active</span>
                        {{else}}
                            <span class="text-danger"><i class="bi bi-x-circle-fill"></i> Inactive</span>
                        {{/if}}
                    </td>
                    <td>
                        <a href="/users/edit/{{_id}}">
                            <i class="bi bi-pencil text-warning"></i>
                        </a>
                    </td>
                    <td>
                        <a href="/users/delete/{{_id}}"
                           onclick="return confirm('Delete this admin?')">
                            <i class="bi bi-trash text-danger"></i>
                        </a>
                    </td>
                </tr>
            {{/each}}
            </tbody>
        </table>
    </div>
</div>