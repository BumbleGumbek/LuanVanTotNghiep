<div class="card shadow">
    <div class="card-body">

        <div class="d-flex align-items-center mb-3">
            <div>
                <h5 class="card-title mb-1">
                    Bảng tài khoản
                </h5>
                <p class="card-text mb-0">
                    Quản lý tất cả tài khoản khách hàng và nhân viên hệ thống.
                </p>
                <p class="card-text mt-2 font-weight-bold">
                    Tổng số lượng tài khoản : {{plainUser.length}}
                </p>
            </div>
            <div class="flex-grow-1 d-flex justify-content-center">
                <form action="/users" method="GET" class="form-inline searchform text-muted">
                    <input
                            class="form-control mr-sm-2 bg-transparent border-0 pl-4 text-muted"
                            type="search"
                            name="keyword"
                            value="{{keyword}}"
                            placeholder="Tìm kiếm tài khoản..."
                            aria-label="Search"
                            style="width: 300px;">
                    {{#if selectedRole}}
                        <input type="hidden" name="role" value="{{selectedRole}}">
                    {{/if}}
                </form>
            </div>

            <div class="d-flex align-items-center">
                <form action="/users" method="GET" class="mr-3 d-flex align-items-center">
                    {{#if keyword}}
                        <input type="hidden" name="keyword" value="{{keyword}}">
                    {{/if}}
                    <select name="role" class="form-control mr-2" onchange="this.form.submit()">
                        <option value="">Tất cả vai trò</option>
                        <option value="customer" {{#if (eq selectedRole 'customer')}}selected{{/if}}>Khách hàng</option>
                        <option value="warehouse" {{#if (eq selectedRole 'warehouse')}}selected{{/if}}>Thủ kho</option>
                        <option value="supplier" {{#if (eq selectedRole 'supplier')}}selected{{/if}}>Nhà cung cấp</option>
                        <option value="store_manager" {{#if (eq selectedRole 'store_manager')}}selected{{/if}}>Quản lý cửa hàng</option>
                    </select>
                </form>

                <a href="/users/create" class="btn btn-primary">
                    Thêm tài khoản
                </a>
            </div>
        </div>

        <table class="table table-hover align-middle">
            <thead>
            <tr>
                <th>#</th>
                <th>Họ và tên</th>
                <th>Email</th>
                <th>Vai trò</th>
                <th>Trạng thái</th>
                <th>Sửa</th>
                <th>Xóa</th>
            </tr>
            </thead>
            <tbody>
            {{#each plainUser}}
                <tr>
                    <td>{{add @index 1}}</td>
                    <td>{{firstName}} {{lastName}}</td>
                    <td>{{email}}</td>
                    <td>
                        <span class="badge {{#if (eq role 'admin')}}badge-danger{{else}}{{#if (eq role 'customer')}}badge-primary{{else}}{{#if (eq role 'warehouse')}}badge-info text-dark{{else}}{{#if (eq role 'supplier')}}badge-warning text-dark{{else}}badge-secondary{{/if}}{{/if}}{{/if}}{{/if}}">
                            {{#if (eq role 'admin')}}Quản trị viên{{/if}}
                            {{#if (eq role 'customer')}}Khách hàng{{/if}}
                            {{#if (eq role 'warehouse')}}Thủ kho{{/if}}
                            {{#if (eq role 'supplier')}}Nhà cung cấp{{/if}}
                            {{#if (eq role 'store_manager')}}Quản lý cửa hàng{{/if}}
                        </span>
                    </td>
                    <td>
                        {{#if status}}
                            <span class="text-success"><i class="bi bi-check-circle-fill"></i> Hoạt động</span>
                        {{else}}
                            <span class="text-danger"><i class="bi bi-x-circle-fill"></i> Khóa</span>
                        {{/if}}
                    </td>
                    <td>
                        <a href="/users/edit/{{_id}}">
                            <i class="bi bi-pencil text-warning"></i>
                        </a>
                    </td>
                    <td>
                        <a href="/users/delete/{{_id}}"
                           onclick="return confirm('Xác nhận xóa tài khoản này?')">
                            <i class="bi bi-trash text-danger"></i>
                        </a>
                    </td>
                </tr>
            {{/each}}
            </tbody>
        </table>
    </div>
</div>