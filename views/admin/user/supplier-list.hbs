<div class="card shadow">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">
             <div>
                  <h5 class="card-title mb-1">
                      Supplier Users Table
                  </h5>
                  <p class="card-text mb-0">
                      Manage all registered supplier users here.
                  </p>
                  <p class="card-text mt-2 font-weight-bold">
                      Total number of supplier users: {{plainUser.length}}
                  </p>
             </div>
             <a href="/users/create" class="btn btn-primary">
                 Add User
             </a>
        </div>

        <table class="table table-hover align-middle">
            <thead>
            <tr>
                <th>#</th>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Email</th>
                <th>Supplier Name</th>
                <th>Status</th>
                <th>Edit</th>
                <th>Delete</th>
            </tr>
            </thead>
            <tbody>
            {{#each plainUser}}
                <tr>
                    <td>{{add @index 1}}</td>
                    <td>{{firstName}}</td>
                    <td>{{lastName}}</td>
                    <td>{{email}}</td>
                    <td>
                        <span class="badge badge-info text-dark">
                            {{supplierName}}
                        </span>
                    </td>
                    <td>
                        {{#if status}}
                            <span class="text-success"><i class="bi bi-check-circle-fill"></i> Active</span>
                        {{else}}
                            <span class="text-danger"><i class="bi bi-x-circle-fill"></i> Inactive</span>
                        {{/if}}
                    </td>
                    <td>
                        <a href="/users/edit/{{_id}}">
                            <i class="bi bi-pencil text-warning"></i>
                        </a>
                    </td>
                    <td>
                        <a href="/users/delete/{{_id}}"
                           onclick="return confirm('Delete this supplier user?')">
                            <i class="bi bi-trash text-danger"></i>
                        </a>
                    </td>
                </tr>
            {{/each}}
            </tbody>
        </table>
    </div>
</div>
