<div class="card shadow">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">
             <div>
                 <h5 class="card-title mb-1">
                     Warehouse Staff Table
                 </h5>
                 <p class="card-text mb-0">
                     Manage all registered warehouse personnel here.
                 </p>
                 <p class="card-text mt-2 font-weight-bold">
                     Total number of warehouse staff : {{plainUser.length}}
                 </p>
             </div>
             <a href="/users/create" class="btn btn-primary">
                 Add Warehouse Staff
             </a>
        </div>

        <table class="table table-hover align-middle">
            <thead>
            <tr>
                <th>#</th>
                <th>Full Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Status</th>
                <th>Edit</th>
                <th>Delete</th>
            </tr>
            </thead>
            <tbody>
            {{#each plainUser}}
                <tr>
                    <td>{{add @index 1}}</td>
                    <td>{{firstName}} {{lastName}}</td>
                    <td>{{email}}</td>
                    <td>
                        <span class="badge badge-info text-dark">
                            {{role}}
                        </span>
                    </td>
                    <td>
                        {{#if status}}
                            <span class="text-success"><i class="bi bi-check-circle-fill"></i> Active</span>
                        {{else}}
                            <span class="text-danger"><i class="bi bi-x-circle-fill"></i> Inactive</span>
                        {{/if}}
                    </td>
                    <td>
                        <a href="/users/edit/{{_id}}">
                            <i class="bi bi-pencil text-warning"></i>
                        </a>
                    </td>
                    <td>
                        <a href="/users/delete/{{_id}}"
                           onclick="return confirm('Delete this warehouse user?')">
                            <i class="bi bi-trash text-danger"></i>
                        </a>
                    </td>
                </tr>
            {{/each}}
            </tbody>
        </table>
    </div>
</div>
