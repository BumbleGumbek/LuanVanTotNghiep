<div class="card shadow">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h5 class="card-title mb-1">
                    Quản lý mã giảm giá
                </h5>
                <p class="card-text mb-0">
                    Quản lý tất cả mã giảm giá.
                </p>
            </div>
            <a href="/admin/coupon/create"
               class="btn btn-primary">
                Tạo mã giảm giá
            </a>
        </div>
        <table class="table table-hover align-middle">
            <thead>
            <tr>
                <th>#</th>
                <th>Mã giảm giá</th>
                <th>Giá trị giảm</th>
                <th>Đơn hàng tối thiểu</th>
                <th>Đã dùng</th>
                <th>Ngày hết hạn</th>
                <th>Trạng thái</th>
                <th>Sửa</th>
                <th>Xóa</th>
            </tr>
            </thead>
            <tbody>

            {{#each coupons}}
                <tr>
                    <td>
                        {{add @index 1}}
                    </td>
                    <td>
                        <span class="font-weight-bold text-primary">
                            {{code}}
                        </span>
                    </td>
                    <td>
                        {{formatCurrency discountValue}} VND
                    </td>
                    <td>
                        {{formatCurrency minOrderValue}} VND
                    </td>
                    <td>
                        {{usedCount}} / {{usageLimit}}
                    </td>
                    <td>
                        {{formatDate expiryDate}}
                    </td>
                    <td>
                        {{#if status}}
                            <span class="badge badge-success">
                                Hoạt động
                            </span>
                        {{else}}
                            <span class="badge badge-danger">
                                Khóa
                            </span>
                        {{/if}}
                    </td>
                    <td>
                        <a href="/admin/coupon/edit/{{_id}}">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-pencil text-warning" viewBox="0 0 16 16"><path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325"/>
                            </svg>
                        </a>
                    </td>
                    <td>
                        <form action="/admin/coupon/{{_id}}?_method=DELETE"
                              method="POST">
                            <button type="submit"
                                    class="border-0 bg-transparent p-0"
                                    onclick="return confirm('Xác nhận xóa mã giảm giá này?')">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-trash3 text-danger" viewBox="0 0 16 16"><path d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.885 16h6.23a2 2 0 0 0 1.994-1.84l.853-10.66h.538a.5.5 0 0 0 0-1zm1.958 1-.846 10.58a1 1 0 0 1-.997.92h-6.23a1 1 0 0 1-.997-.92L3.042 3.5zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47M8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5"/>
                                </svg>
                            </button>
                        </form>
                    </td>
                </tr>
            {{/each}}

            </tbody>
        </table>
    </div>
</div>