<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-12">
            <div class="row align-items-center mb-4">
                <div class="col">
                    <h2 class="h3 page-title text-primary"><i class="fe fe-edit mr-2"></i>Edit Product</h2>
                    <p class="text-muted">Modify the details below to update the jewelry item in your inventory.</p>
                </div>
                <div class="col-auto">
                    <a href="/admin/product" class="btn btn-secondary px-4">
                        <i class="fe fe-arrow-left mr-1"></i> Back to List
                    </a>
                </div>
            </div>

            <form action="/admin/product/edit/{{product._id}}" method="POST" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-8">
                        <div class="card shadow mb-4">
                            <div class="card-header">
                                <strong class="card-title"><i class="fe fe-info mr-2"></i>Basic Information</strong>
                            </div>
                            <div class="card-body">
                                <div class="form-group mb-3">
                                    <label class="form-label font-weight-bold">Product Name <span class="text-danger">*</span></label>
                                    <input type="text" name="name" value="{{product.name}}" class="form-control" placeholder="Enter product name" required>
                                </div>
                                <div class="form-group mb-0">
                                    <label class="form-label font-weight-bold">Description <span class="text-danger">*</span></label>
                                    <textarea name="description" class="form-control" rows="6" placeholder="Describe the product..." required>{{product.description}}</textarea>
                                </div>
                            </div>
                        </div>

                        <div class="card shadow mb-4">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <strong class="card-title"><i class="fe fe-layers mr-2"></i>Product Inventory & Variants</strong>
                                <button type="button" class="btn btn-sm btn-outline-success" id="add-size-btn">
                                    <i class="fe fe-plus-circle mr-1"></i> Add Size
                                </button>
                            </div>
                            <div class="card-body bg-light-lighter">
                                <div id="variant-wrapper">
                                    {{#each product.variants}}
                                        <div class="form-row mb-3 variant-item align-items-center">
                                            <div class="col-5">
                                                <div class="input-group">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text"><i class="fe fe-maximize-2"></i></span>
                                                    </div>
                                                    <input type="text" name="sizes[]" value="{{this.size}}" class="form-control" placeholder="Size" required>
                                                </div>
                                            </div>
                                            <div class="col-5">
                                                <div class="input-group">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text"><i class="fe fe-package"></i></span>
                                                    </div>
                                                    <input type="number" name="quantities[]" value="{{this.quantity}}" class="form-control" placeholder="Quantity" min="0" required>
                                                </div>
                                            </div>
                                            <div class="col-2">
                                                <button type="button" class="btn btn-outline-danger btn-block remove-size-btn" style="height: calc(1.5em + 0.75rem + 2px);">
                                                    <i class="fe fe-trash-2"></i>
                                                </button>
                                            </div>
                                        </div>
                                    {{else}}
                                        <div class="form-row mb-3 variant-item align-items-center">
                                            <div class="col-5">
                                                <div class="input-group">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text"><i class="fe fe-maximize-2"></i></span>
                                                    </div>
                                                    <input type="text" name="sizes[]" class="form-control" placeholder="Size (e.g., S, M, L)" required>
                                                </div>
                                            </div>
                                            <div class="col-5">
                                                <div class="input-group">
                                                    <div class="input-group-prepend">
                                                        <span class="input-group-text"><i class="fe fe-package"></i></span>
                                                    </div>
                                                    <input type="number" name="quantities[]" class="form-control" placeholder="Quantity" min="0" value="0" required>
                                                </div>
                                            </div>
                                            <div class="col-2">
                                                <button type="button" class="btn btn-outline-danger btn-block remove-size-btn" style="height: calc(1.5em + 0.75rem + 2px);">
                                                    <i class="fe fe-trash-2"></i>
                                                </button>
                                            </div>
                                        </div>
                                    {{/each}}
                                </div>
                                <div class="mt-3">
                                    <small class="text-muted"><i class="fe fe-help-circle mr-1"></i> Update sizes and stock levels. Deleting a row will remove that variant upon saving.</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="card shadow mb-4">
                            <div class="card-header">
                                <strong class="card-title"><i class="fe fe-tag mr-2"></i>Pricing & Category</strong>
                            </div>
                            <div class="card-body">
                                <div class="form-group mb-3">
                                    <label class="form-label font-weight-bold">Price (VND) <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <input type="number" name="price" value="{{product.price}}" class="form-control" min="1" required>
                                        <div class="input-group-append">
                                            <span class="input-group-text">VND</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group mb-3">
                                    <label class="form-label font-weight-bold">Category <span class="text-danger">*</span></label>
                                    <select name="category" class="form-control custom-select" required>
                                        <option value="{{product.category._id}}" selected>{{product.category.title}}</option>

                                        {{#each plainCategory}}
                                            <option value="{{this._id}}">{{this.title}}</option>
                                        {{/each}}
                                    </select>
                                </div>
                                <div class="form-group mb-0">
                                    <label class="form-label font-weight-bold">Supplier <span class="text-danger">*</span></label>
                                    <select name="supplier" class="form-control custom-select" required>
                                        <option value="{{product.supplier._id}}" selected>{{product.supplier.name}}</option>

                                        {{#each plainSupplier}}
                                            <option value="{{this._id}}">{{this.name}}</option>
                                        {{/each}}
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="card shadow mb-4">
                            <div class="card-header">
                                <strong class="card-title"><i class="fe fe-image mr-2"></i>Product Media</strong>
                            </div>
                            <div class="card-body">
                                <div class="form-group mb-3">
                                    <label class="form-label font-weight-bold">Current Image</label>
                                    <div class="mb-2 text-center bg-light p-2 rounded">
                                        <img src="{{product.image}}" alt="Product Image" style="max-height: 100px; object-fit: contain;">
                                    </div>
                                    <div class="custom-file">
                                        <input type="file" name="image" class="custom-file-input" id="customFile">
                                        <label class="custom-file-label" for="customFile">Change file...</label>
                                    </div>
                                </div>
                                <div class="text-center my-2">
                                    <span class="badge badge-light px-3 py-2 text-muted">OR</span>
                                </div>
                                <div class="form-group mb-0">
                                    <label class="form-label font-weight-bold">Image URL</label>
                                    <input type="text" name="imageUrl" value="{{product.image}}" class="form-control" placeholder="https://example.com/image.jpg">
                                </div>
                            </div>
                        </div>

                        <div class="card shadow mb-4">
                            <div class="card-header">
                                <strong class="card-title"><i class="fe fe-eye mr-2"></i>Visibility</strong>
                            </div>
                            <div class="card-body">
                                <div class="form-group mb-0">
                                    <label class="form-label font-weight-bold">Product Status</label>
                                    <select name="status" class="form-control custom-select">
                                        <option value="true" {{#if product.status}}selected{{/if}}>Visible (Public)</option>
                                        <option value="false" {{#unless product.status}}selected{{/unless}}>Hidden (Draft)</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg btn-block shadow-sm font-weight-bold py-3">
                            <i class="fe fe-save mr-2"></i> Update Product
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.getElementById('add-size-btn').addEventListener('click', function() {
        const container = document.getElementById('variant-wrapper');
        const row = document.createElement('div');
        row.className = 'form-row mb-3 variant-item align-items-center';
        row.innerHTML = `
            <div class="col-5">
                <div class="input-group">
                    <div class="input-group-prepend">
                        <span class="input-group-text"><i class="fe fe-maximize-2"></i></span>
                    </div>
                    <input type="text" name="sizes[]" class="form-control" placeholder="Size" required>
                </div>
            </div>
            <div class="col-5">
                <div class="input-group">
                    <div class="input-group-prepend">
                        <span class="input-group-text"><i class="fe fe-package"></i></span>
                    </div>
                    <input type="number" name="quantities[]" class="form-control" placeholder="Quantity" min="0" value="0" required>
                </div>
            </div>
            <div class="col-2">
                <button type="button" class="btn btn-outline-danger btn-block remove-size-btn" style="height: calc(1.5em + 0.75rem + 2px);">
                    <i class="fe fe-trash-2"></i>
                </button>
            </div>
        `;
        container.appendChild(row);
    });

    document.getElementById('variant-wrapper').addEventListener('click', function(e) {
        const btn = e.target.closest('.remove-size-btn');
        if (btn) {
            const rows = document.querySelectorAll('.variant-item');
            if (rows.length > 1) {
                btn.closest('.variant-item').remove();
            } else {
                alert('You must have at least one size variant!');
            }
        }
    });

    document.addEventListener('change', function(e) {
        if (e.target.classList.contains('custom-file-input')) {
            var fileName = e.target.files[0].name;
            var label = e.target.nextElementSibling;
            label.innerText = fileName;
        }
    });
</script>