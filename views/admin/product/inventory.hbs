<div class="card shadow">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h5 class="card-title mb-1">Bảng quản lý tồn kho</h5>
                <p class="card-text mb-0">Quản lý tồn kho của tất cả sản phẩm trang sức tại đây.</p>
                <p class="card-text mt-2 font-weight-bold">
                    Tổng số loại sản phẩm: {{plainProduct.length}}
                </p>
            </div>
        </div>

        <table class="table table-hover align-middle">
            <thead>
            <tr>
                <th>#</th>
                <th>Hình ảnh</th>
                <th>Tên sản phẩm</th>
                <th>Danh mục</th>
                <th>Giá</th>
                <th>Số lượng chi tiết</th>
                <th>Trạng thái</th>
                <th>Đã bán</th>
            </tr>
            </thead>
            <tbody>

            {{#each plainProduct}}
                <tr>
                    <td>{{add @index 1}}</td>
                    <td>
                        <img src="{{image}}" alt="{{name}}" width="70" height="70" style="object-fit: cover; border-radius: 10px;">
                    </td>
                    <td>{{name}}</td>
                    <td>{{category.name}}</td>
                    <td>{{formatCurrency price}} VND</td>
                    <td>
                        {{#if this.variants.length}}
                            <ul class="list-unstyled mb-0" style="font-size: 13px; padding-left: 0; min-width: 120px;">
                                {{#each this.variants}}
                                    <li class="mb-1 d-flex align-items-center">
                                        <span class="badge badge-light text-dark font-weight-bold mr-1" style="border: 1px solid #ced4da;">{{this.size}}</span>:
                                        {{#if (eq this.quantity 0)}}
                                            <span class="badge badge-soft-danger text-danger font-weight-bold ml-1">Hết hàng</span>
                                        {{else if (eq this.quantity 1)}}
                                            <span class="text-dark font-weight-bold ml-1">{{this.quantity}} sản phẩm</span>
                                            <span class="badge badge-warning text-white font-weight-bold ml-2 animate-pulse" style="font-size: 10px;">Sắp hết!</span>
                                        {{else if (eq this.quantity 2)}}
                                            <span class="text-dark font-weight-bold ml-1">{{this.quantity}} sản phẩm</span>
                                            <span class="badge badge-warning text-white font-weight-bold ml-2 animate-pulse" style="font-size: 10px;">Sắp hết!</span>
                                        {{else if (eq this.quantity 3)}}
                                            <span class="text-dark font-weight-bold ml-1">{{this.quantity}} sản phẩm</span>
                                            <span class="badge badge-warning text-white font-weight-bold ml-2 animate-pulse" style="font-size: 10px;">Sắp hết!</span>
                                        {{else}}
                                            <span class="text-secondary ml-1">{{this.quantity}} sản phẩm</span>
                                        {{/if}}
                                    </li>
                                {{/each}}
                            </ul>
                        {{else}}
                            <span class="badge badge-soft-danger text-danger">Hết hàng / Không có kích cỡ</span>
                        {{/if}}
                    </td>


                    <td>
                        {{#if (eq totalInventory 0)}}
                            <span class="badge badge-pill badge-danger" style="font-size: 12px; padding: 5px 10px;">Hết hàng</span>
                        {{else if (lte totalInventory 5)}}
                            <span class="badge badge-pill badge-warning text-dark" style="font-size: 12px; padding: 5px 10px;">Sắp hết hàng</span>
                        {{else}}
                            <span class="badge badge-pill badge-success" style="font-size: 12px; padding: 5px 10px;">Còn hàng</span>
                        {{/if}}
                    </td>

                    <td>{{sold}} sản phẩm</td>
                </tr>
            {{/each}}
            </tbody>
        </table>
    </div>
</div>