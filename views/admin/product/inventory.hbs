<div class="card shadow">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h5 class="card-title mb-1">
                    Products Table
                </h5>

                <p class="card-text mb-0">
                    Manage all jewelry products here.
                </p>
                <p class="card-text mt-2 font-weight-bold">
                    Total number of products: {{plainProduct.length}}
                </p>
            </div>
            <div class="d-flex align-items-center">
                <form action="/admin/product" method="GET" class="mr-3 d-flex align-items-center">

                </form>
            </div>
        </div>
        <table class="table table-hover align-middle">
            <thead>
            <tr>
                <th>#</th>
                <th>ID</th>
                <th>Image</th>
                <th>Product Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Qty</th>
                <th>Status</th>
                <th>Sold</th>
            </tr>
            </thead>
            <tbody>

            {{#each plainProduct}}
                <tr>
                    <td>{{add @index 1}}</td>
                    <td>{{_id}}</td>
                    <td>
                        <img src="{{image}}" alt="{{name}}" width="70" height="70" style="object-fit: cover; border-radius: 10px;">
                    </td>
                    <td>
                        {{name}}
                    </td>
                    <td>
                        {{category.title}}
                    </td>
                    <td>
                        {{price}} VND
                    </td>
                    <td>
                        {{#if (eq quantity 0)}}
                            <span class="badge badge-danger">Sold</span>
                        {{else}}
                            <span>{{quantity}} cái</span>
                        {{/if}}
                    </td>
                    <td>
                        {{#if (eq quantity 0)}}
                            <span class="badge badge-pill badge-danger" style="font-size: 12px; padding: 5px 10px;">Out of Stock</span>
                        {{else if (lte quantity 5)}}
                            <span class="badge badge-pill badge-warning text-dark" style="font-size: 12px; padding: 5px 10px;">Low Stock</span>
                        {{else}}
                            <span class="badge badge-pill badge-success" style="font-size: 12px; padding: 5px 10px;">In Stock</span>
                        {{/if}}
                    </td>
                    <td>{{sold}}</td>
                </tr>

            {{/each}}
            </tbody>
        </table>
    </div>
</div>