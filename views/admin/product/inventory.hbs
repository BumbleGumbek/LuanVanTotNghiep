<div class="card shadow">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h5 class="card-title mb-1">Inventory Table</h5>
                <p class="card-text mb-0">Manage all jewelry products here.</p>
                <p class="card-text mt-2 font-weight-bold">
                    Total number of products: {{plainProduct.length}}
                </p>
            </div>
        </div>

        <table class="table table-hover align-middle">
            <thead>
            <tr>
                <th>#</th>
                <th>ID</th>
                <th>Image</th>
                <th>Product Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Qty</th>
                <th>Status</th>
                <th>Sold</th>
            </tr>
            </thead>
            <tbody>

            {{#each plainProduct}}
                <tr>
                    <td>{{add @index 1}}</td>
                    <td>{{_id}}</td>
                    <td>
                        <img src="{{image}}" alt="{{name}}" width="70" height="70" style="object-fit: cover; border-radius: 10px;">
                    </td>
                    <td>{{name}}</td>
                    <td>{{category.name}}</td>
                    <td>{{formatCurrency price}} VND</td>

                    <td>
                        {{#if this.variants.length}}
                            <ul class="list-unstyled mb-0" style="font-size: 13px; padding-left: 0; min-width: 120px;">
                                {{#each this.variants}}
                                    <li class="mb-1 d-flex align-items-center">
                                        <span class="badge badge-light text-dark font-weight-bold mr-1" style="border: 1px solid #ced4da;">Size {{this.size}}</span>:
                                        {{#if (eq this.quantity 0)}}
                                            <span class="badge badge-soft-danger text-danger font-weight-bold ml-1">Sold out</span>
                                        {{else}}
                                            <span class="text-secondary ml-1">{{this.quantity}} items</span>
                                        {{/if}}
                                    </li>
                                {{/each}}
                            </ul>
                        {{else}}
                            <span class="badge badge-danger">No Sizes Available</span>
                        {{/if}}
                    </td>

                    <td>
                        {{#if (eq totalInventory 0)}}
                            <span class="badge badge-pill badge-danger" style="font-size: 12px; padding: 5px 10px;">Out of Stock</span>
                        {{else if (lte totalInventory 5)}}
                            <span class="badge badge-pill badge-warning text-dark" style="font-size: 12px; padding: 5px 10px;">Low Stock</span>
                        {{else}}
                            <span class="badge badge-pill badge-success" style="font-size: 12px; padding: 5px 10px;">In Stock</span>
                        {{/if}}
                    </td>

                    <td>{{sold}} items</td>
                </tr>
            {{/each}}
            </tbody>
        </table>
    </div>
</div>