
<div class="card shadow">
    <div class="card-body">
        <div class="d-flex align-items-center mb-3">
            <div>
                <h5 class="card-title mb-1">
                    Bảng sản phẩm
                </h5>
                <p class="card-text mb-0">
                    Quản lý tất cả sản phẩm trang sức tại đây.
                </p>
                <p class="card-text mt-2 font-weight-bold">
                    Tổng số loại sản phẩm: {{plainProduct.length}}
                </p>
            </div>
            <div class="flex-grow-1 d-flex justify-content-center">
                <form class="form-inline searchform text-muted">
                    <input
                            class="form-control mr-sm-2 bg-transparent border-0 pl-4 text-muted"
                            type="search"
                            name="keyword"
                            value="{{keyword}}"
                            placeholder="Tìm kiếm sản phẩm..."
                            aria-label="Search"
                            style="width: 300px;">
                </form>
            </div>

            <div class="d-flex align-items-center">
                <form action="/admin/product" method="GET" class="mr-3 d-flex align-items-center">
                    <select name="category" class="form-control mr-2" onchange="this.form.submit()">
                        <option value="">Tất cả danh mục</option>
                        {{#each categories}}
                            <option value="{{_id}}" {{#if (eq _id ../selectedCategory)}}selected{{/if}}>
                                {{name}}
                            </option>
                        {{/each}}
                    </select>
                </form>

                {{#if canManageProducts}}
                    <a href="/admin/product/create" class="btn btn-primary">
                        Thêm sản phẩm
                    </a>
                {{/if}}
            </div>
        </div>
        <table class="table table-hover align-middle">
            <thead>
            <tr>
                <th>#</th>
                <th>Hình ảnh</th>
                <th>Tên sản phẩm</th>
                <th>Danh mục</th>
                <th>Giá</th>
                <th>Trạng thái</th>
                <th>Sửa</th>
                <th>Xóa</th>
            </tr>
            </thead>
            <tbody>

            {{#each plainProduct}}
                <tr>
                    <td>{{add @index 1}}</td>
                    <td>
                        <img src="{{image}}" alt="{{name}}" width="70" height="70" style="object-fit: cover; border-radius: 10px;">
                    </td>
                    <td>
                        {{name}}
                    </td>
                    <td>
                        {{category.name}}
                    </td>
                    <td>
                        {{formatCurrency price}} VND
                    </td>
                    <td>
                        {{#if status}}
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-check-circle-fill text-success" viewBox="0 0 16 16">
                                <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0m-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                            </svg>
                        {{else}}
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-x-circle-fill text-danger" viewBox="0 0 16 16">
                                <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0M5.354 4.646a.5.5 0 1 0-.708.708L7.293 8l-2.647 2.646a.5.5 0 0 0 .708.708L8 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L8.707 8l2.647-2.646a.5.5 0 0 0-.708-.708L8 7.293z"/>
                            </svg>
                        {{/if}}
                    </td>

                    <td>
                        <a href="/admin/product/edit/{{_id}}" >
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-pencil text-warning" viewBox="0 0 16 16"><path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325"/>
                            </svg>
                        </a>
                    </td>
                    <td>
                        <form action="/admin/product/{{_id}}?_method=DELETE"
                              method="POST">
                            <button type="submit" class="border-0 bg-transparent p-0">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-trash3 text-danger" viewBox="0 0 16 16"><path d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5M11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.885 16h6.23a2 2 0 0 0 1.994-1.84l.853-10.66h.538a.5.5 0 0 0 0-1zm1.958 1-.846 10.58a1 1 0 0 1-.997.92h-6.23a1 1 0 0 1-.997-.92L3.042 3.5zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47M8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5"/>
                                </svg>
                            </button>
                        </form>
                    </td>
                </tr>

            {{/each}}
            </tbody>
        </table>
    </div>
</div>

<style>
    @keyframes pulse-animation {
        0% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(0.95); }
        100% { opacity: 1; transform: scale(1); }
    }
    .animate-pulse {
        animation: pulse-animation 1.5s infinite ease-in-out;
    }
</style>