<div class="card shadow">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h5 class="card-title mb-1">Bảng thương hiệu</h5>
                <p class="card-text mb-0">Quản lý tất cả thương hiệu tại đây.</p>
            </div>
            <a href="/admin/brand/create" class="btn btn-primary">Thêm thương hiệu</a>
        </div>
        <form action="/admin/brand"
                method="GET"
                class="mb-3">
            <div class="input-group">
                <input
                        type="text"
                        name="keyword"
                        class="form-control"
                        placeholder="Tìm theo tên hoặc mã..."
                        value="{{keyword}}">
                <button
                        class="btn btn-primary"
                        type="submit">
                    Tìm kiếm
                </button>
            </div>
        </form>

        {{#if brands.length}}
            <table class="table table-hover align-middle">
                <thead>
                <tr>
                    <th>#</th>
                    <th>Mã</th>
                    <th>Tên thương hiệu</th>
                    <th>Quốc gia</th>
                    <th>Thứ tự</th>
                    <th>Trạng thái</th>
                    <th>Sửa</th>
                    <th>Xóa</th>
                </tr>
                </thead>
                <tbody>
                {{#each brands}}
                    <tr>
                        <td>{{add @index 1}}</td>
                        <td>{{code}}</td>
                        <td>{{name}}</td>
                        <td>{{country}}</td>
                        <td>{{displayOrder}}</td>
                        <td>
                            {{#if status}}
                                <span class="badge bg-success">
                                    Hoạt động
                                </span>
                            {{else}}
                                <span class="badge bg-danger">
                                    Khóa
                                </span>
                            {{/if}}
                        </td>
                        <td>
                            <a href="/admin/brand/edit/{{_id}}">
                                <svg xmlns="http://www.w3.org/2000/svg"
                                     width="18"
                                     height="18"
                                     fill="currentColor"
                                     class="bi bi-pencil text-warning"
                                     viewBox="0 0 16 16">
                                    <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168z"/>
                                </svg>
                            </a>
                        </td>
                        <td>
                            <a href="/admin/brand/delete/{{_id}}"
                               class="btn p-0"
                               onclick="return confirm('Xác nhận xóa thương hiệu này?')">

                                <svg xmlns="http://www.w3.org/2000/svg"
                                     width="18"
                                     height="18"
                                     fill="currentColor"
                                     class="bi bi-trash3 text-danger"
                                     viewBox="0 0 16 16">
                                    <path d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5"/>
                                </svg>
                            </a>
                        </td>
                    </tr>
                {{/each}}
                </tbody>

            </table>

        {{else}}
            <div class="text-center py-5">
                <h5>Không tìm thấy thương hiệu nào.</h5>
                <p class="text-muted">
                    Hãy tạo thương hiệu đầu tiên.
                </p>
                <a href="/admin/brand/create"
                   class="btn btn-primary">
                    Thêm thương hiệu
                </a>
            </div>
        {{/if}}

    </div>
</div>