<div class="card shadow">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h3 class="card-title mb-1">Tổng quan tồn kho</h3>
                <p class="card-text text-muted mb-0"></p>
            </div>
            <div class="flex-grow-1 d-flex justify-content-center">
                <form action="/admin/inventory/overview" method="GET" class="form-inline searchform text-muted">
                    <input
                            class="form-control mr-sm-2 bg-transparent border-0 pl-4 text-muted"
                            type="search"
                            name="keyword"
                            value="{{keyword}}"
                            placeholder="Tìm kiếm sản phẩm..."
                            aria-label="Search"
                            style="width: 300px;">
                    {{#if selectedFilter}}
                        <input type="hidden" name="filter" value="{{selectedFilter}}">
                    {{/if}}
                    {{#if selectedSort}}
                        <input type="hidden" name="sort" value="{{selectedSort}}">
                    {{/if}}
                </form>
            </div>
            <div class="d-flex align-items-center">
                <button type="button" class="btn btn-sm btn-outline-secondary mr-2" id="btn-select-all">
                    Chọn tất cả
                </button>
                <button type="button" class="btn btn-sm btn-outline-warning mr-2" id="btn-select-low-stock">
                    <i class="fe fe-alert-triangle mr-1"></i> Chọn hàng sắp hết
                </button>
                {{#if canCreateImportRequest}}
                <button type="button" class="btn btn-sm btn-primary" id="btn-create-import-request">
                    <i class="fe fe-plus mr-1"></i> Tạo yêu cầu nhập hàng
                </button>
                {{/if}}
            </div>
        </div>

        <!-- Filter and Sort Controls Form -->
        <div class="bg-light p-3 rounded mb-4 shadow-sm border">
            <form action="/admin/inventory/overview" method="GET" class="form-inline d-flex justify-content-between align-items-center flex-wrap">
                {{#if keyword}}
                    <input type="hidden" name="keyword" value="{{keyword}}">
                {{/if}}
                <div class="d-flex flex-wrap align-items-center">
                    <div class="form-group mr-4">
                        <label for="filter" class="mr-2 font-weight-bold text-secondary"><i class="fe fe-filter mr-1"></i>Lọc trạng thái:</label>
                        <select name="filter" id="filter" class="form-control custom-select custom-select-sm" onchange="this.form.submit()" style="min-width: 160px;">
                            {{#each filterOptions}}
                                <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.text}}</option>
                            {{/each}}
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="sort" class="mr-2 font-weight-bold text-secondary"><i class="fe fe-list mr-1"></i>Sắp xếp theo:</label>
                        <select name="sort" id="sort" class="form-control custom-select custom-select-sm" onchange="this.form.submit()" style="min-width: 180px;">
                            {{#each sortOptions}}
                                <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.text}}</option>
                            {{/each}}
                        </select>
                    </div>
                </div>
                <div class="text-muted mt-2 mt-sm-0">
                    Hiển thị <strong class="text-dark">{{plainProducts.length}}</strong> sản phẩm
                </div>
            </form>
        </div>

        {{#if success_message}}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                {{success_message}}
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        {{/if}}

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="thead-light">
                    <tr>
                        <th style="width: 4%;" class="text-center">
                            <input type="checkbox" id="check-all-products">
                        </th>
                        <th style="width: 5%;">#</th>
                        <th style="width: 10%;">Hình ảnh</th>
                        <th style="width: 20%;">Tên sản phẩm</th>
                        <th style="width: 12%;">Kích cỡ & Tồn kho</th>
                        <th style="width: 8%;" class="text-center">Đã nhập</th>
                        <th style="width: 8%;" class="text-center">Đã bán</th>
                        <th style="width: 10%;" class="text-center">Tồn kho hiện tại</th>
                        <th style="width: 10%;">Ngày nhập gần nhất</th>
                        <th style="width: 8%;" class="text-center">Số ngày bày bán</th>
                        <th style="width: 9%;" class="text-center">Trạng thái</th>
                        <th style="width: 10%;" class="text-center">Hiệu suất</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each plainProducts}}
                        <tr>
                            <td class="text-center">
                                <input type="checkbox" class="product-checkbox" value="{{_id}}" data-status="{{statusKey}}">
                            </td>
                            <td>{{add @index 1}}</td>
                            <td>
                                <img src="{{image}}" alt="{{name}}" width="60" height="60" style="object-fit: cover; border-radius: 8px; border: 1px solid #dee2e6;">
                            </td>
                            <td>
                                <span class="font-weight-bold text-dark d-block">{{name}}</span>
                                <small class="text-muted">Danh mục: {{category.name}}</small>
                            </td>
                            <td>
                                {{#if variants.length}}
                                    <ul class="list-unstyled mb-0" style="font-size: 13px; padding-left: 0;">
                                        {{#each variants}}
                                            <li class="mb-1 d-flex align-items-center">
                                                <span class="badge badge-light text-dark font-weight-bold mr-1" style="border: 1px solid #ced4da; min-width: 24px; text-align: center;">{{this.size}}</span>:
                                                {{#if (eq this.quantity 0)}}
                                                    <span class="badge badge-soft-danger text-danger font-weight-bold ml-1">Hết</span>
                                                {{else}}
                                                    <span class="text-secondary ml-1 font-weight-bold">{{this.quantity}} sản phẩm</span>
                                                {{/if}}
                                            </li>
                                        {{/each}}
                                    </ul>
                                {{else}}
                                    <span class="badge badge-soft-danger text-danger">Không có phân loại</span>
                                {{/if}}
                            </td>
                            <td class="text-center font-weight-bold text-info">{{imported}}</td>
                            <td class="text-center font-weight-bold text-success">{{sold}}</td>
                            <td class="text-center font-weight-bold text-dark">{{currentStock}}</td>
                            <td>
                                <span class="d-block">{{lastImportDate}}</span>
                            </td>
                            <td class="text-center font-weight-bold">
                                {{#if (eq daysOnShelf 'N/A')}}
                                    <span class="text-muted">N/A</span>
                                {{else}}
                                    <span class="text-dark">{{daysOnShelf}} ngày</span>
                                {{/if}}
                            </td>
                            <td class="text-center">
                                <span class="badge badge-pill badge-{{statusBadge}} px-2 py-1" style="font-size: 11px;">
                                    {{statusText}}
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="badge badge-pill badge-{{perfBadge}} px-2 py-1" style="font-size: 11px;">
                                    {{perfText}}
                                </span>
                            </td>
                        </tr>
                    {{/each}}
                    {{#unless plainProducts.length}}
                        <tr>
                            <td colspan="12" class="text-center text-muted py-5">
                                <i class="fe fe-inbox fe-24 d-block mb-2"></i>
                                Không có sản phẩm nào khớp với bộ lọc đã chọn.
                            </td>
                        </tr>
                    {{/unless}}
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const checkAll = document.getElementById('check-all-products');
    const checkboxes = document.querySelectorAll('.product-checkbox');
    const btnSelectAll = document.getElementById('btn-select-all');
    const btnSelectLowStock = document.getElementById('btn-select-low-stock');
    const btnCreateImportRequest = document.getElementById('btn-create-import-request');

    // Header checkbox toggles all
    if (checkAll) {
        checkAll.addEventListener('change', function () {
            checkboxes.forEach(cb => cb.checked = checkAll.checked);
        });
    }

    // Select All Button
    if (btnSelectAll) {
        btnSelectAll.addEventListener('click', function () {
            const allChecked = Array.from(checkboxes).every(cb => cb.checked);
            checkboxes.forEach(cb => cb.checked = !allChecked);
            if (checkAll) checkAll.checked = !allChecked;
        });
    }

    // Select Low Stock Button
    if (btnSelectLowStock) {
        btnSelectLowStock.addEventListener('click', function () {
            // First uncheck all
            checkboxes.forEach(cb => cb.checked = false);
            if (checkAll) checkAll.checked = false;

            // Check only low stock
            checkboxes.forEach(cb => {
                if (cb.getAttribute('data-status') === 'lowStock') {
                    cb.checked = true;
                }
            });
        });
    }

    // Create Import Request Button
    if (btnCreateImportRequest) {
        btnCreateImportRequest.addEventListener('click', function () {
            const selectedIds = [];
            checkboxes.forEach(cb => {
                if (cb.checked) {
                    selectedIds.push(cb.value);
                }
            });

            if (selectedIds.length === 0) {
                alert('Vui lòng chọn ít nhất một sản phẩm.');
                return;
            }

            // Redirect to create request page with query param
            window.location.href = '/admin/import-request/create?productIds=' + selectedIds.join(',');
        });
    }
});
</script>
