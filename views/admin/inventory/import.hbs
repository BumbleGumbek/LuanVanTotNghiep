<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-12">
            <div class="row align-items-center mb-4">
                <div class="col">
                    <h2>Import Stock</h2>
                    <p class="text-muted">Import quantities for existing jewelry products or create a new product during entry.</p>
                </div>
                <div class="col-auto">
                    <a href="/admin/inventory/overview" class="btn btn-secondary px-4">
                        <i class="fe fe-arrow-left mr-1"></i> Back to Overview
                    </a>
                </div>
            </div>

            {{#if success_message}}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    {{success_message}}
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
            {{/if}}
            {{#if error_message}}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    {{error_message}}
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
            {{/if}}

            <form action="/admin/inventory/import" method="POST" enctype="multipart/form-data">
                <input type="hidden" name="productSelect" id="productSelect" value="existing">
                <input type="hidden" name="sizeSelect" id="sizeSelect" value="existing">

                <div class="row">
                    <!-- Left Column: Core Import Configuration -->
                    <div class="col-md-7">
                        <div class="card shadow mb-4">
                            <div class="card-header">
                                <strong class="card-title"><i class="fe fe-package mr-2"></i>Select Product & Size</strong>
                            </div>
                            <div class="card-body">
                                <div class="form-group mb-3">
                                    <label class="form-label font-weight-bold">Product <span class="text-danger">*</span></label>
                                    <select name="productId" id="productId" class="form-control custom-select" required>
                                        <option value="" disabled selected>-- Select Product --</option>
                                        {{#each plainProducts}}
                                            <option value="{{_id}}">{{name}} (Category: {{category.name}})</option>
                                        {{/each}}
                                        <option value="__new__" class="font-weight-bold text-success">+ Create New Product --</option>
                                    </select>
                                </div>

                                <div class="form-group mb-3" id="size-select-group">
                                    <label class="form-label font-weight-bold">Size <span class="text-danger">*</span></label>
                                    <select name="sizeName" id="sizeName" class="form-control custom-select">
                                        <option value="" disabled selected>-- Select Size --</option>
                                    </select>
                                </div>

                                <div class="form-group mb-3" id="new-size-section" style="display: none;">
                                    <label class="form-label font-weight-bold">New Size Name <span class="text-danger">*</span></label>
                                    <input type="text" name="newSizeName" id="newSizeName" class="form-control" placeholder="e.g. 6, 7, 8, S, M">
                                </div>

                                <div class="form-group mb-3">
                                    <label class="form-label font-weight-bold">Import Quantity <span class="text-danger">*</span></label>
                                    <input type="number" name="quantity" class="form-control" min="1" placeholder="Enter import quantity" required>
                                </div>

                                <div class="form-group mb-0">
                                    <label class="form-label font-weight-bold">Note / Reason</label>
                                    <textarea name="note" class="form-control" rows="3" placeholder="Describe the reason for import (e.g. Monthly stock refresh, Supplier delivery)"></textarea>
                                </div>
                            </div>
                        </div>

                        <!-- Sub-form: Create New Product (Only visible when __new__ is selected) -->
                        <div id="new-product-section" style="display: none;">
                            <div class="card shadow mb-4">
                                <div class="card-header">
                                    <strong class="card-title text-success"><i class="fe fe-plus-circle mr-2"></i>New Product Information</strong>
                                </div>
                                <div class="card-body">
                                    <div class="form-group mb-3">
                                        <label class="form-label font-weight-bold">Product Name <span class="text-danger">*</span></label>
                                        <input type="text" name="name" id="newProductName" class="form-control">
                                    </div>
                                    <div class="form-group mb-0">
                                        <label class="form-label font-weight-bold">Description <span class="text-danger">*</span></label>
                                        <textarea name="description" id="newProductDescription" class="form-control" rows="4"></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column: Pricing & Meta (Only shown/validated for New Products) -->
                    <div class="col-md-5">
                        <div id="new-product-meta-section" style="display: none;">
                            <div class="card shadow mb-4">
                                <div class="card-header">
                                    <strong class="card-title"><i class="fe fe-tag mr-2"></i>Pricing & Classification</strong>
                                </div>
                                <div class="card-body">
                                    <div class="form-group mb-3">
                                        <label class="form-label font-weight-bold">Price (VND) <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <input type="number" name="price" id="newProductPrice" class="form-control" min="0" placeholder="0">
                                            <div class="input-group-append">
                                                <span class="input-group-text">VND</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="form-group mb-3">
                                        <label class="form-label font-weight-bold">Category <span class="text-danger">*</span></label>
                                        <select name="category" id="newProductCategory" class="form-control custom-select">
                                            <option value="" disabled selected>-- Select Category --</option>
                                            {{#each plainCategories}}
                                                <option value="{{_id}}">{{name}}</option>
                                            {{/each}}
                                        </select>
                                    </div>
                                    <div class="form-group mb-0">
                                        <label class="form-label font-weight-bold">Supplier <span class="text-danger">*</span></label>
                                        <select name="supplier" id="newProductSupplier" class="form-control custom-select">
                                            <option value="" disabled selected>-- Select Supplier --</option>
                                            {{#each plainSuppliers}}
                                                <option value="{{_id}}">{{name}}</option>
                                            {{/each}}
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <div class="card shadow mb-4">
                                <div class="card-header">
                                    <strong class="card-title"><i class="fe fe-image mr-2"></i>Media & Settings</strong>
                                </div>
                                <div class="card-body">
                                    <div class="form-group mb-3">
                                        <label class="form-label font-weight-bold">Upload Image</label>
                                        <div class="custom-file">
                                            <input type="file" name="image" class="custom-file-input" id="customFile">
                                            <label class="custom-file-label" for="customFile">Choose file</label>
                                        </div>
                                    </div>
                                    <div class="text-center my-2">
                                        <span class="badge badge-light px-3 py-2 text-muted">OR</span>
                                    </div>
                                    <div class="form-group mb-3">
                                        <label class="form-label font-weight-bold">Image URL</label>
                                        <input type="text" name="imageUrl" class="form-control" placeholder="https://example.com/image.jpg">
                                    </div>
                                    <div class="form-row">
                                        <div class="form-group col-md-6 mb-0">
                                            <label class="form-label font-weight-bold">Alert Threshold</label>
                                            <input type="number" name="lowStockThreshold" class="form-control" min="0" value="5">
                                        </div>
                                        <div class="form-group col-md-6 mb-0">
                                            <label class="form-label font-weight-bold">Status</label>
                                            <select name="status" class="form-control custom-select">
                                                <option value="true">Visible</option>
                                                <option value="false">Hidden</option>
                                            </select>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- General Submission Card -->
                        <div class="card shadow">
                            <div class="card-body">
                                <button type="submit" class="btn btn-primary btn-lg btn-block shadow-sm font-weight-bold py-3">
                                    <i class="fe fe-check mr-2"></i> Complete Stock Import
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    window.productsData = {{{productsJson}}};
</script>
<script src="/js/inventory.js"></script>
