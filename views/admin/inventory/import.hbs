<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-12">
            <div class="row align-items-center mb-4">
                <div class="col">
                    <h2>Nhập kho</h2>
                    <p class="text-muted">Nhập số lượng cho các sản phẩm trang sức hiện có hoặc tạo sản phẩm mới trong khi nhập.</p>
                </div>
                <div class="col-auto">
                    <a href="/admin/inventory/overview" class="btn btn-secondary px-4">
                        <i class="fe fe-arrow-left mr-1"></i> Quay lại tổng quan
                    </a>
                </div>
            </div>

            {{#if success_message}}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    {{success_message}}
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
            {{/if}}
            {{#if error_message}}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    {{error_message}}
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
            {{/if}}

            <form action="/admin/inventory/import" method="POST" enctype="multipart/form-data">
                <input type="hidden" name="productSelect" id="productSelect" value="existing">
                <input type="hidden" name="sizeSelect" id="sizeSelect" value="existing">

                <div class="row">
                    <!-- Left Column: Core Import Configuration -->
                    <div class="col-md-7">
                        <div class="card shadow mb-4">
                            <div class="card-header">
                                <strong class="card-title"><i class="fe fe-package mr-2"></i>Chọn sản phẩm & kích cỡ</strong>
                            </div>
                            <div class="card-body">
                                <div class="form-group mb-3">
                                    <label class="form-label font-weight-bold">Sản phẩm <span class="text-danger">*</span></label>
                                    <select name="productId" id="productId" class="form-control select2" required style="width: 100%;">
                                        <option value="" disabled selected>-- Chọn sản phẩm --</option>
                                        {{#each plainProducts}}
                                            <option value="{{_id}}">{{name}} (Danh mục: {{category.name}})</option>
                                        {{/each}}
                                    </select>
                                </div>

                                <div class="form-group mb-3" id="size-select-group">
                                    <label class="form-label font-weight-bold">Kích cỡ <span class="text-danger">*</span></label>
                                    <select name="sizeName" id="sizeName" class="form-control custom-select">
                                        <option value="" disabled selected>-- Chọn kích cỡ --</option>
                                    </select>
                                </div>

                                <div class="form-group mb-3" id="new-size-section" style="display: none;">
                                    <label class="form-label font-weight-bold">Tên kích cỡ mới <span class="text-danger">*</span></label>
                                    <input type="text" name="newSizeName" id="newSizeName" class="form-control" placeholder="VD: 6, 7, 8, S, M">
                                </div>

                                <div class="form-group mb-3">
                                    <label class="form-label font-weight-bold">Số lượng nhập <span class="text-danger">*</span></label>
                                    <input type="number" name="quantity" class="form-control" min="1" placeholder="Nhập số lượng nhập" required>
                                </div>

                                <div class="form-group mb-0">
                                    <label class="form-label font-weight-bold">Ghi chú / Lý do</label>
                                    <textarea name="note" class="form-control" rows="3" placeholder="Mô tả lý do nhập hàng"></textarea>
                                </div>
                            </div>
                        </div>

                        <!-- Sub-form: Create New Product (Only visible when __new__ is selected) -->
                        <div id="new-product-section" style="display: none;">
                            <div class="card shadow mb-4">
                                <div class="card-header">
                                    <strong class="card-title text-success"><i class="fe fe-plus-circle mr-2"></i>Thông tin sản phẩm mới</strong>
                                </div>
                                <div class="card-body">
                                    <div class="form-group mb-3">
                                        <label class="form-label font-weight-bold">Tên sản phẩm <span class="text-danger">*</span></label>
                                        <input type="text" name="name" id="newProductName" class="form-control">
                                    </div>
                                    <div class="form-group mb-0">
                                        <label class="form-label font-weight-bold">Mô tả <span class="text-danger">*</span></label>
                                        <textarea name="description" id="newProductDescription" class="form-control" rows="4"></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column: Pricing & Meta (Only shown/validated for New Products) -->
                    <div class="col-md-5">
                        <div id="new-product-meta-section" style="display: none;">
                            <div class="card shadow mb-4">
                                <div class="card-header">
                                    <strong class="card-title"><i class="fe fe-tag mr-2"></i>Giá bán & Phân loại</strong>
                                </div>
                                <div class="card-body">
                                    <div class="form-group mb-3">
                                        <label class="form-label font-weight-bold">Giá bán (VND) <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <input type="number" name="price" id="newProductPrice" class="form-control" min="0" placeholder="0">
                                            <div class="input-group-append">
                                                <span class="input-group-text">VND</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- General Submission Card -->
                        <div class="card shadow">
                            <div class="card-body">
                                <button type="submit" class="btn btn-primary btn-lg btn-block shadow-sm font-weight-bold py-3">
                                    <i class="fe fe-check mr-2"></i> Hoàn tất nhập kho
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    window.productsData = {{{productsJson}}};
</script>
<script src="/js/inventory.js"></script>
