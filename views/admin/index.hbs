<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-12">
            <div class="row align-items-center mb-2">
                <div class="col">
                    <h2 class="h5 page-title">Jewelry Store Dashboard</h2>
                </div>
                <div class="col-auto">
                    <form class="form-inline">
                        <div class="form-group d-none d-lg-inline">
                            <label for="reportrange" class="sr-only">Date Ranges</label>
                            <div id="reportrange" class="px-2 py-2 text-muted">
                                <span class="small"></span>
                            </div>
                        </div>
                        <div class="form-group">
                            <button type="button" class="btn btn-sm"><span class="fe fe-refresh-ccw fe-16 text-muted"></span></button>
                            <button type="button" class="btn btn-sm mr-2"><span class="fe fe-filter fe-16 text-muted"></span></button>
                        </div>
                    </form>
                </div>
            </div>
            <div class="mb-2 align-items-center">
                <div class="card shadow mb-4">
                    <div class="card-body">
                        <div class="row mt-1 align-items-center">
                            <div class="col-12 col-lg-4 text-left pl-4">
                                <p class="mb-1 small text-muted">Total Revenue</p>
                                <span class="h3">
                                    {{totalRevenue}} VND
                                </span>
                                <span class="small text-muted">+20%</span>
                                <span class="fe fe-arrow-up text-success fe-12"></span>
                                <p class="text-muted mt-2"> Overall revenue generated from jewelry sales and completed customer orders. </p>
                            </div>
                            <div class="col-6 col-lg-2 text-center py-4">
                                <p class="mb-1 small text-muted">Today's Orders</p>
                                <span class="h3">
                                    {{totalOrders}}
                                </span>
                                <span class="small text-muted">+20%</span>
                                <span class="fe fe-arrow-up text-success fe-12"></span>
                            </div>
                            <div class="col-6 col-lg-2 text-center py-4">
                                <p class="mb-1 small text-muted">
                                    All Orders
                                </p>
                                <span class="h3">
                                    {{totalOrders}}
                                </span>
                                <span class="fe fe-arrow-up text-success fe-12"></span>
                            </div>

                        </div>
                        <div class="chartbox mr-4">
                            <div id="areaChart"></div>
                        </div>
                    </div> <!-- .card-body -->
                </div> <!-- .card -->
            </div>
            <div class="row items-align-baseline">
                <div class="col-md-12 col-lg-5">
                    <div class="card shadow eq-card mb-4">
                        <div class="card-body mb-n3">
                            <div class="row items-align-baseline h-100">
                                <div class="col-md-6 my-3">
                                    <p class="mb-0"><strong class="mb-0 text-uppercase text-muted">Monthly Revenue</strong></p>
                                    <h3>
                                        {{totalRevenue}}
                                    </h3>
                                    <p class="text-muted">Revenue generated from jewelry sales this month.</p>
                                </div>
                                <div class="col-md-6 my-4 text-center">
                                    <div class="chart-box mx-4">
                                        <div id="radialbarWidget"></div>
                                    </div>
                                </div>
                                <div class="col-md-6 border-top py-3">
                                    <p class="mb-1"><strong class="text-muted">Total Products</strong></p>
                                    <h4 class="mb-0">
                                        {{totalProducts}}
                                    </h4>
                                    <p class="small text-muted mb-0"><span>37.7% Last week</span></p>
                                </div> <!-- .col -->
                                <div class="col-md-6 border-top py-3">
                                    <p class="mb-1"><strong class="text-muted">Total Customers</strong></p>
                                    <h4 class="mb-0">
                                        {{totalCustomers}}
                                    </h4>
                                    <p class="small text-muted mb-0"><span>-18.9% Last week</span></p>
                                </div> <!-- .col -->
                            </div>
                        </div> <!-- .card-body -->
                    </div> <!-- .card -->
                </div> <!-- .col -->
                <div class="col-md-12 col-lg-4">
                    <div class="card shadow eq-card mb-4">
                        <div class="card-body">
                            <div class="d-flex mt-3 mb-4">
                                <div class="flex-fill pt-2">
                                    <p class="mb-0 text-muted">Total</p>
                                    <h4 class="mb-0">
                                        {{totalProducts}}
                                    </h4>
                                    <span class="small text-muted">+37.7%</span>
                                </div>
                                <div class="flex-fill chart-box mt-n2">
                                    <div id="barChartWidget"></div>
                                </div>
                            </div> <!-- .d-flex -->
                            <div class="row border-top">
                                <div class="col-md-6 pt-4">
                                    <h6 class="mb-0">108 <span class="small text-muted">+37.7%</span></h6>
                                    <p class="mb-0 text-muted">Cost</p>
                                </div>
                                <div class="col-md-6 pt-4">
                                    <h6 class="mb-0">1168 <span class="small text-muted">-18.9%</span></h6>
                                    <p class="mb-0 text-muted">Revenue</p>
                                </div>
                            </div> <!-- .row -->
                        </div> <!-- .card-body -->
                    </div> <!-- .card -->
                </div>
                <div class="col-md-12 col-lg-3">
                    <div class="card shadow eq-card mb-4">
                        <div class="card-header">
                            <strong class="card-title">
                                Order Statistics
                            </strong>
                        </div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Pending</span>
                                <strong>{{orderStats.Pending}}</strong>
                            </div>

                            <div class="d-flex justify-content-between mb-2">
                                <span>Confirmed</span>
                                <strong>{{orderStats.Confirmed}}</strong>
                            </div>

                            <div class="d-flex justify-content-between mb-2">
                                <span>Processing</span>
                                <strong>{{orderStats.Processing}}</strong>
                            </div>

                            <div class="d-flex justify-content-between mb-2">
                                <span>Shipping</span>
                                <strong>{{orderStats.Shipping}}</strong>
                            </div>

                            <div class="d-flex justify-content-between mb-2">
                                <span>Delivered</span>
                                <strong class="text-success">
                                    {{orderStats.Delivered}}
                                </strong>
                            </div>

                            <div class="d-flex justify-content-between">
                                <span>Cancelled</span>
                                <strong class="text-danger">
                                    {{orderStats.Cancelled}}
                                </strong>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-12">
                    <div class="card shadow mt-4">
                        <div class="card-header">
                            <strong class="card-title">Top Selling Products</strong>
                            <a class="float-right small text-primary"
                               href="/admin/product">
                                View all
                            </a>
                        </div>
                        <div class="card-body my-n2">
                            <table class="table table-striped table-hover table-borderless">
                                <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Image</th>
                                    <th>Product Name</th>
                                    <th>Price</th>
                                    <th>Sold</th>
                                </tr>
                                </thead>
                                <tbody>
                                {{#each bestSellingProducts}}
                                    <tr>
                                        <td>{{add @index 1}}</td>
                                        <td>
                                            <img src="{{image}}"
                                                 alt="{{name}}"
                                                 width="60"
                                                 height="60"
                                                 style="object-fit: cover; border-radius: 8px;">
                                        </td>
                                        <td>{{name}}</td>
                                        <td>{{price}} VND</td>
                                        <td>{{sold}}</td>
                                    </tr>
                                {{/each}}
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="card shadow mt-4">
                        <div class="card-header">
                            <strong>Low Stock Products</strong>
                            <a class="float-right small text-primary"
                               href="/admin/product">
                                View all
                            </a>
                        </div>

                        <div class="card-body">
                            <table class="table table-striped table-hover table-borderless">
                                <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Image</th>
                                    <th>Product Name</th>
                                    <th >Price</th>
                                    <th class="text-center">Remaining Stock</th>
                                </tr>
                                </thead>

                                <tbody>
                                {{#each lowStockProducts}}
                                    <tr>
                                        <td>{{add @index 1}}</td>
                                        <td>
                                            <img src="{{image}}"
                                                 alt="{{name}}"
                                                 width="60"
                                                 height="60"
                                                 style="object-fit: cover; border-radius: 8px;">
                                        </td>
                                        <td>{{name}}</td>
                                        <td>{{price}} VND</td>
                                        <td class="text-center">
                                            {{#if (lte stock 2)}}
                                                <span class="badge badge-danger">{{stock}}</span>
                                            {{else}}
                                                <span class="badge badge-warning">{{stock}}</span>
                                            {{/if}}
                                        </td>
                                    </tr>
                                {{/each}}
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="card shadow mt-4">
                        <div class="card-header">
                            <strong>
                                Recent Orders
                            </strong>
                        </div>
                        <div class="card-body">
                            <table class="table table-hover">
                                <thead>
                                <tr>
                                    <th>Order ID</th>
                                    <th>Customer</th>
                                    <th>Total</th>
                                    <th>Status</th>
                                </tr>
                                </thead>
                                <tbody>
                                {{#each recentOrders}}
                                    <tr>
                                        <td>
                                            {{shortId _id}}
                                        </td>
                                        <td>
                                            {{user.firstName}}
                                            {{user.lastName}}
                                        </td>
                                        <td>
                                            {{totalPrice}} VND
                                        </td>
                                        <td>
                                            <span class="dot dot-lg mr-2
                                                {{#if (eq status 'Pending')}}bg-warning{{/if}}
                                                {{#if (eq status 'Confirmed')}}bg-info{{/if}}
                                                {{#if (eq status 'Processing')}}bg-secondary{{/if}}
                                                {{#if (eq status 'Shipping')}}bg-primary{{/if}}
                                                {{#if (eq status 'Delivered')}}bg-success{{/if}}
                                                {{#if (eq status 'Cancelled')}}bg-danger{{/if}}"></span>
                                                                        <span class="font-weight-bold
                                                {{#if (eq status 'Pending')}}text-warning{{/if}}
                                                {{#if (eq status 'Confirmed')}}text-info{{/if}}
                                                {{#if (eq status 'Processing')}}text-secondary{{/if}}
                                                {{#if (eq status 'Shipping')}}text-primary{{/if}}
                                                {{#if (eq status 'Delivered')}}text-success{{/if}}
                                                {{#if (eq status 'Cancelled')}}text-danger{{/if}}">{{status}}</span>
                                        </td>
                                    </tr>
                                {{/each}}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</div>