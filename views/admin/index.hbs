<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-12">
            <div class="row align-items-center mb-2">
                <div class="col">
                    <h2 class="h5 page-title">Bảng điều khiển Cửa hàng Trang sức</h2>
                </div>
                <div class="col-auto">
                    <form class="form-inline">
                        <div class="form-group d-none d-lg-inline">
                            <label for="reportrange" class="sr-only">Khoảng thời gian</label>
                            <div id="reportrange" class="px-2 py-2 text-muted">
                                <span class="small"></span>
                            </div>
                        </div>
                        <div class="form-group">
                            <button type="button" class="btn btn-sm"><span class="fe fe-refresh-ccw fe-16 text-muted"></span></button>
                            <button type="button" class="btn btn-sm mr-2"><span class="fe fe-filter fe-16 text-muted"></span></button>
                        </div>
                    </form>
                </div>
            </div>
            <div class="mb-2 align-items-center">
                <div class="card shadow mb-4">
                    <div class="card-body">
                        <div class="row mt-1 align-items-center">
                            <div class="col-12 col-lg-3 text-left pl-4">
                                <p class="mb-1 small text-muted">Tổng doanh thu</p>
                                <span class="h3">
                                    {{formatCurrency totalRevenue}} VND
                                </span>
                                <span class="small text-muted"></span>
                                <span class="fe fe-arrow-up text-success fe-12"></span>
                                <p class="text-muted mt-2"> Doanh thu toàn bộ được tạo từ doanh số bán trang sức và các đơn hàng hoàn thành của khách hàng. </p>
                            </div>
                            <div class="col-6 col-lg-3 text-center py-4">
                                <p class="mb-1 small text-muted">Doanh thu hôm nay</p>
                                <span class="h3">
                                    {{formatCurrency todayRevenue}} VND
                                </span>
                                <span class="fe fe-arrow-up text-success fe-12"></span>
                            </div>
                            <div class="col-6 col-lg-3 text-center py-4">
                                <p class="mb-1 small text-muted">Đơn hàng hôm nay</p>
                                <span class="h3">
                                    {{ordersToday}}
                                </span>
                                <span class="small text-muted">Today</span>
                                <span class="fe fe-arrow-up text-success fe-12"></span>
                            </div>
                            <div class="col-6 col-lg-3 text-center py-4">
                                <p class="mb-1 small text-muted">
                                    Tất cả đơn hàng
                                </p>
                                <span class="h3">
                                    {{totalOrders}}
                                </span>
                                <span class="fe fe-arrow-up text-success fe-12"></span>
                            </div>

                        </div>
                        <div class="chartbox mr-4">
                            <div id="areaChart"></div>
                        </div>
                    </div> <!-- .card-body -->
                </div> <!-- .card -->
            </div>
            <div class="row items-align-baseline">
                <div class="col-md-12 col-lg-5">
                    <div class="card shadow eq-card mb-4">
                        <div class="card-body mb-n3">
                            <div class="row items-align-baseline h-100">
                                <div class="col-md-6 my-3">
                                    <p class="mb-0"><strong class="mb-0 text-uppercase text-muted">Doanh thu tháng</strong></p>
                                    <h3>
                                        {{formatCurrency monthlyRevenue}} VND
                                    </h3>
                                    <p class="text-muted">Doanh thu được tạo từ doanh số bán trang sức trong tháng này.</p>
                                </div>
                                <div class="col-md-6 my-4 text-center">
                                    <div class="chart-box mx-4">
                                        <div id="radialbarWidget"></div>
                                    </div>
                                </div>
                                <div class="col-md-6 border-top py-3">
                                    <p class="mb-1"><strong class="text-muted">Tổng số sản phẩm</strong></p>
                                    <h4 class="mb-0">
                                        {{totalProducts}}
                                    </h4>
                                    <p class="small text-muted mb-0"><span>Danh mục sản phẩm hiện tại</span></p>
                                </div> <!-- .col -->
                                <div class="col-md-6 border-top py-3">
                                    <p class="mb-1"><strong class="text-muted">Tổng số khách hàng</strong></p>
                                    <h4 class="mb-0">
                                        {{totalCustomers}}
                                    </h4>
                                    <p class="mb-0 text-muted">
                                        Mới hôm nay:
                                        <strong>{{newCustomersToday}}</strong>
                                    </p>
                                    <p class="small text-muted mb-0"><span></span></p>
                                </div> <!-- .col -->
                            </div>
                        </div> <!-- .card-body -->
                    </div> <!-- .card -->
                </div> <!-- .col -->
                <div class="col-md-12 col-lg-4">
                    <div class="card shadow mb-4">
                        <div class="card-body">
                            <div class="d-flex mt-3 mb-4">
                                <div class="flex-fill pt-2">
                                    <p class="mb-0 text-muted">Tổng cộng</p>
                                    <h4 class="mb-0">
                                        {{totalProducts}}
                                    </h4>
                                </div>
                                <div class="flex-fill chart-box mt-n2">
                                    <div id="barChartWidget"></div>
                                </div>
                            </div> <!-- .d-flex -->
                        </div> <!-- .card-body -->
                    </div> <!-- .card -->

                    <div class="card shadow mb-4">
                        <div class="card-body">
                            <p class="mb-1 small text-muted">Doanh thu năm</p>
                            <h4 class="mb-0">
                                {{formatCurrency yearlyRevenue}} VND
                            </h4>
                            <p class="text-muted small mt-2">Doanh thu tích lũy được tạo từ các đơn hàng hoàn thành trong năm nay.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-12 col-lg-3">
                    <div class="card shadow eq-card mb-4">
                        <div class="card-header">
                            <strong class="card-title">
                                Thống kê đơn hàng
                            </strong>
                        </div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Chờ thanh toán</span>
                                <strong>{{orderStats.PendingPayment}}</strong>
                            </div>

                            <div class="d-flex justify-content-between mb-2">
                                <span>Đã thanh toán</span>
                                <strong>{{orderStats.Paid}}</strong>
                            </div>

                            <div class="d-flex justify-content-between mb-2">
                                <span>Đang vận chuyển</span>
                                <strong>{{orderStats.Shipping}}</strong>
                            </div>

                            <div class="d-flex justify-content-between mb-2">
                                <span>Đã hoàn thành</span>
                                <strong>{{orderStats.Completed}}</strong>
                            </div>

                            <div class="d-flex justify-content-between">
                                <span>Đã hủy</span>
                                <strong class="text-danger">
                                    {{orderStats.Cancelled}}
                                </strong>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-12">
                    <div class="card shadow mt-4">
                        <div class="card-header">
                            <strong class="card-title">Sản phẩm bán chạy nhất</strong>
                            <a class="float-right small text-primary"
                               href="/admin/inventory/overview">
                                Xem tất cả
                            </a>
                        </div>
                        <div class="card-body my-n2">
                            <table class="table table-striped table-hover table-borderless">
                                <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Hình ảnh</th>
                                    <th>Tên sản phẩm</th>
                                    <th class="text-right">Giá bán</th>
                                    <th class="text-center">Đã bán</th>
                                    <th class="text-center">Tồn kho</th>
                                    <th class="text-center">Trạng thái</th>
                                </tr>
                                </thead>
                                <tbody>
                                {{#each bestSellingProducts}}
                                    <tr>
                                        <td>{{add @index 1}}</td>
                                        <td>
                                            <img src="{{image}}"
                                                 alt="{{name}}"
                                                 width="60"
                                                 height="60"
                                                 style="object-fit: cover; border-radius: 8px;">
                                        </td>
                                        <td>{{name}}</td>
                                        <td class="text-right">{{formatCurrency price}} VND</td>
                                        <td class="text-center">
                                            {{sold}}
                                        </td>

                                        <td class="text-center">
                                            {{stock}}
                                        </td>

                                        <td class="text-center">
                                            {{#if (eq stock 0)}}
                                                <span class="badge badge-danger">
                                                    Out of Stock
                                                </span>

                                            {{else if (lte stock lowStockThreshold)}}
                                                <span class="badge badge-warning">
                                                    Low Stock
                                                </span>

                                            {{else}}
                                                <span class="badge badge-success">
                                                    In Stock
                                                </span>
                                            {{/if}}
                                        </td>
                                    </tr>
                                {{/each}}
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="card shadow mt-4">
                        <div class="card-header">
                            <strong>Sản phẩm sắp hết hàng</strong>
                            <a class="float-right small text-primary"
                               href="/admin/product">
                                Xem tất cả
                            </a>
                        </div>

                        <div class="card-body">
                            <table class="table table-striped table-hover table-borderless">
                                <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Hình ảnh</th>
                                    <th>Tên sản phẩm</th>
                                    <th class="text-center">Tồn kho thấp nhất</th>
                                    <th class="text-center">Trạng thái</th>
                                </tr>
                                </thead>

                                <tbody>
                                {{#each lowStockProducts}}
                                    <tr>
                                        <td>{{add @index 1}}</td>
                                        <td>
                                            <img src="{{image}}"
                                                 alt="{{name}}"
                                                 width="60"
                                                 height="60"
                                                 style="object-fit: cover; border-radius: 8px;">
                                        </td>
                                        <td>{{name}}</td>
                                        <td class="text-center">
                                            Size {{lowStockVariant.size}} (Qty: {{stock}})
                                        </td>

                                        <td class="text-center">
                                            {{#if (eq stock 0)}}
                                                <span class="badge badge-danger">
                                                    Out of Stock
                                                </span>
                                            {{else}}
                                                <span class="badge badge-warning">
                                                    Low Stock
                                                </span>
                                            {{/if}}
                                        </td>
                                    </tr>
                                {{/each}}
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="card shadow mt-4">
                        <div class="card-header">
                            <strong>
                                Đơn hàng gần đây
                            </strong>
                        </div>
                        <div class="card-body">
                            <table class="table table-hover">
                                <thead>
                                <tr>
                                    <th>Mã đơn hàng</th>
                                    <th>Khách hàng</th>
                                    <th>Ngày đặt</th>
                                    <th>Tổng tiền</th>
                                    <th>Thanh toán</th>
                                    <th>Trạng thái đơn</th>
                                    <th>Hành động</th>
                                </tr>
                                </thead>
                                <tbody>
                                {{#each recentOrders}}
                                    <tr>
                                        <td>
                                            {{shortId _id}}
                                        </td>
                                        <td>
                                            {{#if user}}
                                                {{user.firstName}} {{user.lastName}}
                                            {{else}}
                                                Khách vãng lai
                                            {{/if}}
                                        </td>
                                        <td>
                                            {{formatDate createdAt}}
                                        </td>
                                        <td>
                                            {{formatCurrency totalPrice}} VND
                                        </td>
                                        <td>
                                            {{#if (eq paymentStatus 'Paid')}}
                                                <span class="badge badge-success">Đã trả</span>
                                            {{else if (eq paymentStatus 'Failed')}}
                                                <span class="badge badge-danger">Thất bại</span>
                                            {{else}}
                                                <span class="badge badge-warning">Chưa trả</span>
                                            {{/if}}
                                        </td>
                                        <td>
                                            <span class="dot dot-lg mr-2
                                                {{#if (eq status 'Paid')}}bg-info{{/if}}
                                                {{#if (eq status 'Shipping')}}bg-primary{{/if}}
                                                {{#if (eq status 'Completed')}}bg-success{{/if}}
                                                {{#if (eq status 'Cancelled')}}bg-danger{{/if}}">
                                            </span>
                                            <span class="font-weight-bold
                                                {{#if (eq status 'Paid')}}text-info{{/if}}
                                                {{#if (eq status 'Shipping')}}text-primary{{/if}}
                                                {{#if (eq status 'Completed')}}text-success{{/if}}
                                                {{#if (eq status 'Cancelled')}}text-danger{{/if}}">
                                                {{#if (eq status 'PendingPayment')}}Chờ thanh toán{{/if}}
                                                {{#if (eq status 'Paid')}}Đã thanh toán{{/if}}
                                                {{#if (eq status 'Shipping')}}Đang vận chuyển{{/if}}
                                                {{#if (eq status 'Completed')}}Hoàn thành{{/if}}
                                                {{#if (eq status 'Cancelled')}}Đã hủy{{/if}}
                                              </span>
                                        </td>
                                        <td>
                                            <a href="/admin/orders/invoice/{{_id}}" class="btn btn-sm btn-outline-primary">Xem</a>
                                        </td>
                                    </tr>
                                {{/each}}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</div>
<script>
    const chartRaw = {{{chartDataJSON}}};
    window.dashboardChart = {
        labels: chartRaw.labels,
        revenue: chartRaw.revenue,
        monthlyPercentage: {{monthlyRevenuePercentage}},
        orderStats: [
            {{orderStats.PendingPayment}},
            {{orderStats.Paid}},
            {{orderStats.Shipping}},
            {{orderStats.Completed}},
            {{orderStats.Cancelled}}
        ]
    };
</script>