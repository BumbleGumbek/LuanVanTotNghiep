<div class="card shadow">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h5 class="card-title mb-1">My Import Requests</h5>
            </div>
        </div>

        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Request Code</th>
                    <th>Status</th>
                    <th>Created Date</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {{#each requests}}
                    <tr>
                        <td><a href="/supplier/import-request/{{_id}}" class="font-weight-bold text-primary">{{requestCode}}</a></td>
                        <td>
                            {{#if (eq status "Pending")}}
                                <span class="badge badge-warning">Pending</span>
                            {{/if}}
                            {{#if (eq status "Delivered")}}
                                <span class="badge badge-info">Delivered</span>
                            {{/if}}
                            {{#if (eq status "Completed")}}
                                <span class="badge badge-success">Completed</span>
                            {{/if}}
                            {{#if (eq status "Rejected")}}
                                <span class="badge badge-danger">Rejected</span>
                            {{/if}}
                        </td>
                        <td>{{createdAt}}</td>
                        <td>
                            <a href="/supplier/import-request/{{_id}}" class="btn btn-sm btn-info">View Details</a>
                        </td>
                    </tr>
                {{else}}
                    <tr>
                        <td colspan="4" class="text-center">No import requests found.</td>
                    </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
</div>
