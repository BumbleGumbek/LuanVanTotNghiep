<div class="breadcrumb-option">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 col-md-6 col-sm-6">
                <div class="breadcrumb__text">
                    <h2>Thanh toán</h2>
                </div>
            </div>
            <div class="col-lg-6 col-md-6 col-sm-6">
                <div class="breadcrumb__links">
                    <a href="/">Trang chủ</a>
                    <span>Thanh toán</span>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Breadcrumb End -->

<!-- Checkout Section Begin -->
<section class="checkout spad">
    <div class="container">
        <div class="checkout__form">
            <form action="/checkout" method="POST">
                <div class="row">
                    <div class="col-lg-8 col-md-6">
                        <div class="checkout__input">
                            <p>Mã giảm giá</p>
                            <input
                                    type="text"
                                    name="couponCode"
                                    placeholder="Nhập mã giảm giá">
                        </div>
                        <h6 class="checkout__title">Thông tin giao hàng</h6>
                        <div class="checkout__input">
                            <p>Họ và tên<span>*</span></p>
                            <input
                                    type="text"
                                    name="receiverName"
                                    required>
                        </div>
                        <div class="checkout__input">
                            <p>Địa chỉ giao hàng<span>*</span></p>

                            <input
                                    type="text"
                                    name="detailAddress"
                                    placeholder="Nhập địa chỉ giao hàng chi tiết"
                                    required>
                        </div>
                        <div class="row">
                            <div class="col-lg-6">
                                <div class="checkout__input">
                                    <p>Số điện thoại<span>*</span></p>
                                    <input type="text"
                                           name="receiverPhone"
                                           required>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <div class="checkout__input">
                                    <p>Email<span>*</span></p>
                                    <input type="email"
                                           value="{{user.email}}"
                                           readonly>
                                </div>
                            </div>
                        </div>
                        <div class="checkout__input__checkbox">
                            <label for="diff-acc">
                                Ghi chú về đơn hàng, ví dụ: ghi chú đặc biệt khi giao hàng
                                <input type="checkbox" id="diff-acc">
                                <span class="checkmark"></span>
                            </label>
                        </div>
                        <div class="checkout__input">
                            <p>Ghi chú đơn hàng</p>
                            <textarea name="note"
                                      class="form-control"
                                      rows="4"></textarea>
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-6">
                        <div class="checkout__order">
                            <h6 class="order__title">Đơn hàng</h6>
                            <div class="checkout__order__products">Sản phẩm <span>Tổng cộng</span></div>
                            <ul class="checkout__total__products">
                                {{#each product}}
                                    <li>
                                        <samp>{{quantity}} x </samp>
                                        {{name}}
                                        <span>{{formatCurrency total}} VND</span>
                                    </li>
                                {{/each}}
                            </ul>
                            <ul class="checkout__total__all">
                                <li>
                                    Tổng số lượng
                                    <span>{{totalQty}}</span>
                                </li>
                                <li>
                                    Tổng tiền
                                    <span>{{formatCurrency totalPrice}} VND</span>
                                </li>
                            </ul>
                            <button type="submit" class="site-btn">ĐẶT HÀNG</button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</section>