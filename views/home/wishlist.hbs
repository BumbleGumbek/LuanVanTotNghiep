<style>
    /* CSS Fix for Wishlist Images */
    .wishlist__product__item__pic {
        width: 100px;
        height: 100px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        border: 1px solid #f2f2f2;
        background: #fff;
    }

    .wishlist__product__item__pic img {
        width: 100%;
        height: 100%;
        object-fit: contain; /* Keeps aspect ratio and contains within 100x100 */
    }
</style>

<section class="wishlist spad">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="wishlist__cart__table">
                    <table>
                        <thead>
                        <tr>
                            <th>Sản phẩm</th>
                            <th>Tên sản phẩm</th>
                            <th>Đơn giá</th>
                            <th>Tình trạng</th>
                            <th></th>
                            <th></th>
                        </tr>
                        </thead>

                        <tbody>
                        {{#each wishlist}}
                            <tr>

                                <!-- PRODUCT -->
                                <td class="wishlist__product__item">
                                    <div class="wishlist__product__item__pic">
                                        <img src="{{product.image}}" alt="">
                                    </div>
                                </td>
                                <td>
                                    <div class="wishlist__product__item__text">
                                        <h5>{{product.name}}</h5>
                                    </div>
                                </td>

                                <!-- PRICE -->
                                <td class="cart__price">
                                    {{formatCurrency product.price}} VND
                                </td>

                                <!-- STOCK -->
                                <td class="cart__stock">
                                    {{#if product.status}}
                                        Còn hàng
                                    {{else}}
                                        Hết hàng
                                    {{/if}}
                                </td>

                                <!-- ADD TO CART -->
                                <td class="cart__btn">

                                    <form action="/add-cart/{{product._id}}" method="POST">

                                        <input type="hidden"
                                               name="qty"
                                               value="1">

                                        <a href="/product-detail/{{product._id}}"
                                           class="primary-btn">
                                            Xem chi tiết
                                        </a>

                                    </form>

                                </td>

                                <!-- REMOVE -->
                                <td class="cart__close">
                                    <a href="/wishlist/remove/{{_id}}">
                                        <span class="icon_close"></span>
                                    </a>
                                </td>

                            </tr>
                        {{/each}}
                        </tbody>

                    </table>
                </div>
            </div>
        </div>
    </div>
</section>