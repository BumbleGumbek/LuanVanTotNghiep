<section class="container mt-5 mb-5">

    <div class="row justify-content-center">

        <div class="col-lg-6">

            <div class="breadcrumb__text mb-4">
                <h2>Change Password</h2>
            </div>

            <form
                    action="/change-password"
                    method="POST">

                <div class="form-group">

                    <label>
                        Current Password
                    </label>

                    <input
                            type="password"
                            class="form-control"
                            name="currentPassword"
                            required>

                </div>

                <div class="form-group">

                    <label>
                        New Password
                    </label>

                    <input
                            type="password"
                            class="form-control"
                            name="newPassword"
                            required>

                </div>

                <div class="form-group">

                    <label>
                        Confirm New Password
                    </label>

                    <input
                            type="password"
                            class="form-control"
                            name="confirmPassword"
                            required>

                </div>

                <button
                        type="submit"
                        class="site-btn">

                    Change Password

                </button>

            </form>

        </div>

    </div>

</section>