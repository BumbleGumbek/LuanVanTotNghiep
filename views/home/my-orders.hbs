<!-- Breadcrumb Begin -->
<div class="breadcrumb-option">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 col-md-6 col-sm-6">
                <div class="breadcrumb__text">
                    <h2>My Orders</h2>
                </div>
            </div>
            <div class="col-lg-6 col-md-6 col-sm-6">
                <div class="breadcrumb__links">
                    <a href="/">Home</a>
                    <span>My Orders</span>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Breadcrumb End -->

<!-- Shopping Cart Section Begin -->
<section class="shopping-cart spad">
    <div class="container">
        {{#if orders.length}}
            <div class="row">
                <div class="col-lg-12">
                    <div class="shopping__cart__table">
                        <table>
                            <thead>
                            <tr>
                                <th style="width:200px;">Order ID</th>
                                <th style="width:220px;">Date</th>
                                <th>Products</th>
                                <th style="width:200px;">Total</th>
                                <th style="width:200px;">Status</th>
                                <th style="width:120px;"></th>
                            </tr>
                            </thead>
                            <tbody>
                            {{#each orders}}
                                <tr>
                                    <td class="product__cart__item" style="width:200px;">
                                        <div class="product__cart__item__text">
                                            <h6>{{shortId _id}}</h6>
                                        </div>
                                    </td>
                                    <td class="cart__price" style="width:220px;">
                                        {{formatDate createdAt}}
                                    </td>
                                    <td class="product__cart__item">
                                        <div class="product__cart__item__text">
                                            <ul class="list-unstyled mb-0">
                                            {{#each items}}
                                                <li class="small">
                                                    <span>{{this.name}}</span>
                                                    <span class="text-muted ml-1">(Size {{this.size}}) x{{this.quantity}}</span>
                                                </li>
                                            {{/each}}
                                            </ul>
                                        </div>
                                    </td>
                                    <td class="cart__price" style="width:180px;">
                                        <span>{{formatCurrency totalPrice}} VND</span>
                                    </td>
                                    <td class="cart__price" style="width:180px;">
                                        <span class="badge badge-pill px-3 py-2
                                            {{#if (eq status 'PendingPayment')}}badge-warning text-dark{{/if}}
                                            {{#if (eq status 'Paid')}}badge-info{{/if}}
                                            {{#if (eq status 'Confirmed')}}badge-primary{{/if}}
                                            {{#if (eq status 'Processing')}}badge-secondary{{/if}}
                                            {{#if (eq status 'Shipping')}}badge-info{{/if}}
                                            {{#if (eq status 'Delivered')}}badge-success{{/if}}
                                            {{#if (eq status 'Cancelled')}} badge-danger{{/if}}">
                                            {{status}}
                                        </span>

                                    </td>
                                    <td class="cart__close">
                                        <a href="/my-orders/{{_id}}" class="primary-btn" style="padding: 10px 20px; font-size: 12px;">
                                            View
                                        </a>
                                    </td>
                                </tr>
                            {{/each}}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        {{else}}
            <div class="row">
                <div class="col-lg-12 text-center">
                    <div class="section-title">
                        <span>Empty</span>
                        <h2>You have no orders</h2>
                    </div>
                    <a href="/" class="primary-btn">Continue Shopping</a>
                </div>
            </div>
        {{/if}}
    </div>
</section>
<!-- Shopping Cart Section End -->