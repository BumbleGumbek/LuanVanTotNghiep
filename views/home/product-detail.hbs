
<section class="product-details spad">
    <div class="container">
        <div class="row">
            <div class="col-lg-6">
                <div class="product__details__img">
                    <div class="product__details__big__img">
                        <img class="big_img img-fluid"
                             src="{{product.image}}"
                             alt="{{product.name}}">
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="product__details__text">
                    <h4>{{product.name}}</h4>
                    <h5>
                        {{formatCurrency product.price}} VND
                    </h5>
                    <p>{{product.description}}</p>
                    <ul>
                        <li>Tổng số lượng: <span>{{product.totalQuantity}}</span></li>
                        <li>Tình trạng:
                            <span>
                                {{#if product.totalQuantity}}
                                    Còn hàng
                                {{else}}
                                    Hết hàng
                                {{/if}}
                            </span>
                        </li>
                    </ul>

                    <form action="/add-cart/{{product._id}}" method="POST">
                        <div class="product__details__option__size" style="margin-bottom: 30px; border-top: 1px solid #e1e1e1; padding-top: 20px;">
                            <span style="font-weight: 600; color: #111111; display: block; margin-bottom: 12px; font-size: 14px; text-transform: uppercase; letter-spacing: 1px;">
                                Chọn kích cỡ:
                            </span>
                            <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                                {{#each product.variants}}
                                    {{#if this.quantity}}
                                        <label class="size-label" data-stock="{{this.quantity}}" style="position: relative; display: inline-flex; align-items: center; justify-content: center; min-width: 85px; padding: 10px 12px; border: 1px solid #e1e1e1; cursor: pointer; border-radius: 2px; background: #ffffff; margin: 0; transition: all 0.2s;">
                                            <input type="radio" name="size" value="{{this.size}}" required style="position: absolute; opacity: 0; width: 0; height: 0; margin: 0;">
                                            <div style="text-align: center; width: 100%;">
                                                <span style="font-weight: 600; font-size: 13px; color: #111111; display: block;">Kích cỡ {{this.size}}</span>
                                                <span style="color: #04274c; font-size: 11px; display: block; margin-top: 2px;">(còn {{this.quantity}})</span>
                                            </div>
                                        </label>
                                    {{else}}
                                        <label class="size-label disabled" style="display: inline-flex; align-items: center; justify-content: center; min-width: 85px; padding: 10px 12px; border: 1px solid #f1f1f1; color: #b2b2b2; background: #fafafa; cursor: not-allowed; border-radius: 2px; margin: 0; text-align: center;">
                                            <div>
                                                <span style="font-weight: 500; font-size: 13px; text-decoration: line-through; display: block;">Kích cỡ {{this.size}}</span>
                                                <small style="color: #cc0000; font-size: 11px; display: block; margin-top: 2px;">Hết hàng</small>
                                            </div>
                                        </label>
                                    {{/if}}
                                {{/each}}
                            </div>
                        </div>

                        <div class="product__details__option">
                            <div class="option-group">
                                <div class="quantity">
                                    <div class="pro-qty">
                                        <input type="number" name="qty" value="1" min="1">
                                    </div>
                                </div>

                                <button type="submit" name="action" value="add_to_cart" class="primary-btn" style="border: none;">
                                    Thêm vào giỏ
                                </button>

                                <button type="submit" name="action" value="buy_now" class="primary-btn" style="background: #111111; border: none;">
                                    Mua ngay
                                </button>

                                <a href="/wishlist/add/{{product._id}}" class="heart__btn">
                                    <i class="fa fa-heart {{#if product.inWishlist}}heart-active{{/if}}" style="font-size: 20px;"></i>
                                </a>
                            </div>
                        </div>

                    </form>
                </div>
            </div>
        </div>
        <section class="related-products spad">
            <div class="container">

                <div class="row">
                    <div class="col-lg-12 text-center">
                        <div class="section-title">
                            <h2>Sản phẩm liên quan</h2>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="related__products__slider owl-carousel">

{{#each relatedProducts}}
                            <div class="col-lg-3">
                                <div class="product__item">
                                    <div class="product__item__pic set-bg"
                                         data-setbg="{{image}}">
                                        <div class="product__label">
                                        </div>
                                        <ul class="product__item__pic__hover">
                                            <li>
                                                <a href="/wishlist/add/{{_id}}">
                                                    <i class="fa fa-heart {{#if inWishlist}}heart-active{{/if}}"></i>
                                                </a>
                                            </li>
                                        </ul>
                                        <a href="/product-detail/{{_id}}" class="w-100 h-100 d-block"></a>
                                    </div>
                                    <div class="product__item__text">
                                        <h6>
                                            <a href="/product-detail/{{_id}}">
                                                {{name}}
                                            </a>
                                        </h6>
                                        <div class="product__item__price">
                                            {{formatCurrency price}} VND
                                        </div>
                                        <div class="cart_add">
                                            <a href="/product-detail/{{this._id}}">Chi tiết</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
{{/each}}
                    </div>
                </div>

            </div>
        </section>
    </div>
</section>
