
<section class="shopping-cart spad">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="breadcrumb__links">
                    <a href="/">Trang chủ</a>
                    <a href="/my-orders">Đơn hàng của tôi</a>
                    <span>Chi tiết đơn hàng</span>
                </div>
            </div>
            <div class="col-lg-12">
                <div class="section-title" style="text-align: left; margin-bottom: 30px;">
                    <h2>Đơn hàng</h2>
                    <h3>{{shortId order._id}}</h3>
                    <p>{{formatDate order.createdAt}}</p>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-lg-12">
                <div class="order-status-tracker-container">
                    <div class="order-status-tracker">
                        <div class="tracker-step {{#if order.isPaidStep}}active{{/if}}">
                            <div class="step-icon"><i class="fa fa-credit-card "></i></div>
                            <div class="step-label">Đã thanh toán</div>
                        </div>
                        <div class="tracker-line {{#if order.isShippingStep}}active{{/if}}"></div>
                        <div class="tracker-step {{#if order.isShippingStep}}active{{/if}}">
                            <div class="step-icon"><i class="fa fa-truck"></i></div>
                            <div class="step-label">Đang giao hàng</div>
                        </div>
                        <div class="tracker-line {{#if order.isCompletedStep}}active{{/if}}"></div>
                        <div class="tracker-step {{#if order.isCompletedStep}}active{{/if}}">
                            <div class="step-icon"><i class="fa fa-check-circle"></i></div>
                            <div class="step-label">Hoàn thành</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-8">
                <div class="shopping__cart__table">
                    <table>
                        <thead>
                        <tr>
                            <th>Trang sức</th>
                            <th>Kích cỡ</th>
                            <th style="width:160px;text-align:center;">Đơn giá</th>
                            <th style="width:100px;text-align:center;">
                                Số lượng
                            </th>

                            <th style="width:160px;text-align:right;">
                                Thành tiền
                            </th>
                        </tr>
                        </thead>
                        <tbody>
                        {{#each order.items}}
                            <tr>
                                <td class="product__cart__item" style="width: 350px;">
                                    <div class="product__cart__item__pic">
                                        <img src="{{this.image}}" alt="{{this.name}}" width="90">
                                    </div>
                                    <div class="product__cart__item__text">
                                        <h6>{{this.name}}</h6>
                                    </div>
                                </td>
                                <td class="cart__price" style="width: 80px; text-align: center;">
                                    <span class="badge badge-light" style="font-size: 14px;">{{this.size}}</span>
                                </td>
                                <td class="cart__price" style="width: 160px;">
                                    {{formatCurrency this.price_at_purchase}} VND
                                </td>
                                <td class="cart__price" style="text-align:center;width:100px;" >
                                    {{this.quantity}}
                                </td>
                                <td class="cart__price" style="text-align:right;width:160px;">
                                    {{formatCurrency this.subtotal}} VND
                                </td>
                            </tr>
                        {{/each}}
                        </tbody>
                    </table>
                </div>

                <div class="row">
                    <div class="col-lg-6 col-md-6 col-sm-6 col-6">
                        <div class="continue__btn">
                            <a href="/my-orders"><i class="fa fa-arrow-left"></i> Quay lại lịch sử</a>
                        </div>
                    </div>
                    {{#if (eq order.status 'Completed')}}
                        <div class="col-lg-6 col-md-6 col-sm-6 col-6">
                            <div class="continue__btn update__btn">
                                {{#if order.isFullyReviewed}}
                                    <a href="/review/{{order._id}}" class="site-btn">
                                        Xem đánh giá
                                    </a>
                                {{else}}
                                    <a href="/review/{{order._id}}" class="site-btn">
                                        Đánh giá sản phẩm
                                    </a>
                                {{/if}}
                            </div>
                        </div>
                    {{/if}}
                </div>
            </div>

            <div class="col-lg-4">
                <div class="cart__total" style="margin-top: 0; margin-bottom: 30px;">
                    <h6>Tóm tắt đơn hàng</h6>
                    <ul>
                        <li>Trạng thái
                            <span class="badge badge-pill px-3 py-2
                                {{#if (eq order.status 'PendingPayment')}}badge-warning text-dark{{/if}}
                                {{#if (eq order.status 'Paid')}}badge-primary{{/if}}
                                {{#if (eq order.status 'Shipping')}}badge-info{{/if}}
                                {{#if (eq order.status 'Completed')}}badge-success{{/if}}
                                {{#if (eq order.status 'Cancelled')}}badge-danger{{/if}}">

                                {{#if (eq order.status 'PendingPayment')}}Chờ thanh toán{{/if}}
                                {{#if (eq order.status 'Paid')}}Đã thanh toán{{/if}}
                                {{#if (eq order.status 'Shipping')}}Đang giao hàng{{/if}}
                                {{#if (eq order.status 'Completed')}}Hoàn thành{{/if}}
                                {{#if (eq order.status 'Cancelled')}}Đã hủy{{/if}}
                            </span>
                        </li>
                        <li>Trạng thái thanh toán <span style="color: #111;">{{#if (eq order.status 'PendingPayment')}}Chưa thanh toán{{else}}Đã thanh toán{{/if}}</span></li>
                        <li>Phương thức thanh toán <span style="color: #111;">{{#if order.paymentMethod}}{{order.paymentMethod}}{{else}}Chuyển khoản ngân hàng{{/if}}</span></li>
                        <li style="border-top: 1px solid #f2f2f2; padding-top: 15px; margin-top: 15px;">
                            Tổng tiền
                            <span style="color: #d10024; font-size: 20px;">
                                {{formatCurrency order.totalPrice}} VND
                            </span>
                        </li>
                        {{#if qrCodeImage}}
                        <div class="card mt-4">
                            <div class="card-body text-center">

                                <h5>
                                    Quét mã QR để theo dõi đơn hàng
                                </h5>
                                <img
                                        src="{{{qrCodeImage}}}"
                                        width="220"
                                        class="img-fluid"
                                        alt="QR Code">
                            </div>
                        </div>
                        {{/if}}
                    </ul>

                    {{#if (eq order.status 'PendingPayment')}}
                        <a href="/payment/{{order._id}}"
                           class="site-btn"
                           style="display:block;text-align:center;margin-bottom:10px;">
                            Tiến hành thanh toán
                        </a>

                        <form action="/cancel-order/{{order._id}}" method="POST">
                            <button type="submit"
                                    class="site-btn"
                                    style="background:#dc3545;width:100%;">
                                Hủy đơn hàng
                            </button>
                        </form>

                    {{/if}}

<!--                    {{#if (eq order.status 'Shipping')}}-->
<!--                        <form action="/confirm-received/{{order._id}}" method="POST">-->
<!--                            <button type="submit"-->
<!--                                    class="site-btn"-->
<!--                                    style="width:100%; display:block; text-align:center; margin-bottom:10px; background: #28a745;">-->
<!--                                Confirm received-->
<!--                            </button>-->
<!--                        </form>-->
<!--                    {{/if}}-->
                </div>

                <div class="cart__total" style="margin-top: 0;">
                    <h6>Thông tin giao hàng</h6>
                    <ul style="border-bottom: none;">
                        <li style="display: block; margin-bottom: 10px;">
                            <p style="margin-bottom: 0; font-weight: 600; color: #111;">Người nhận</p>
                            <span style="float: none; font-size: 14px; color: #444;">{{order.shippingAddress.receiverName}}</span>
                        </li>
                        <li style="display: block; margin-bottom: 10px;">
                            <p style="margin-bottom: 0; font-weight: 600; color: #111;">Số điện thoại</p>
                            <span style="float: none; font-size: 14px; color: #444;">{{order.shippingAddress.receiverPhone}}</span>
                        </li>
                        <li style="display: block; margin-bottom: 10px;">
                            <p style="margin-bottom: 0; font-weight: 600; color: #111;">Địa chỉ</p>
                            <span style="float: none; font-size: 14px; color: #444; line-height: 1.4;">
                                {{order.shippingAddress.detailAddress}}
                            </span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>