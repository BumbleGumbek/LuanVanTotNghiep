<section class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <div class="breadcrumb__text text-center mb-4">
                <h2>Hồ sơ của tôi</h2>
            </div>

            <div class="card-body">
                <p>
                    <strong>Tên:</strong>
                    {{userProfile.firstName}}
                </p>

                <p>
                    <strong>Họ:</strong>
                    {{userProfile.lastName}}
                </p>

                <p>
                    <strong>Số điện thoại:</strong>
                    {{userProfile.phone}}
                </p>

                <p>
                    <strong>Địa chỉ:</strong>
                    {{userProfile.address}}
                </p>

                <p>
                    <strong>Email:</strong>
                    {{userProfile.email}}
                </p>

                <div class="mt-4 d-flex">

                    <a href="/profile/edit"
                       class="site-btn mr-3">
                        Cập nhật thông tin
                    </a>

                    <a href="/change-password"
                       class="site-btn">
                        Đổi mật khẩu
                    </a>

                </div>
            </div>

        </div>
    </div>
</section>