<!-- Hero Section Begin -->
<section class="hero">
    <div class="hero__slider owl-carousel">

        <div class="hero__item set-bg" data-setbg="img/hero/hero-1.jpg">

        </div>
    </div>
</section>
<!-- Hero Section End -->

<!-- About Section Begin -->
<section class="about spad">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 col-md-6">
                <div class="about__text">
                    <div class="section-title">
                        <span>About Our Jewelry Store</span>
                        <h2>Elegant Jewelry Crafted With Passion</h2>
                    </div>
                    <p>Discover elegant jewelry collections designed with
                        precision, passion and modern. Every piece
                        reflects beauty, confidence and sophistication.</p>
                </div>
            </div>
            <div class="col-lg-6 col-md-6">
                <div class="about__bar">
                    <div class="about__bar__item">
                        <p>Jewelry Design</p>
                        <div id="bar1" class="barfiller">
                            <div class="tipWrap"><span class="tip"></span></div>
                            <span class="fill" data-percentage="95"></span>
                        </div>
                    </div>
                    <div class="about__bar__item">
                        <p>Customer Satisfaction</p>
                        <div id="bar2" class="barfiller">
                            <div class="tipWrap"><span class="tip"></span></div>
                            <span class="fill" data-percentage="80"></span>
                        </div>
                    </div>
                    <div class="about__bar__item">
                        <p>Elegant Collection</p>
                        <div id="bar3" class="barfiller">
                            <div class="tipWrap"><span class="tip"></span></div>
                            <span class="fill" data-percentage="90"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- About Section End -->

<!-- Categories Section Begin -->
<div class="categories">
    <div class="container">
        <div class="row">
            <div class="categories__slider owl-carousel">
                <div class="categories__item">
                    <div class="categories__item__icon">
                        <i class="fa-solid fa-diamond"></i>
                        <h5>Rings</h5>
                    </div>
                </div>
                <div class="categories__item">
                    <div class="categories__item__icon">
                        <i class="fa-regular fa-gem"></i>
                        <h5>Necklaces</h5>
                    </div>
                </div>
                <div class="categories__item">
                    <div class="categories__item__icon">
                        <i class="fa-regular fa-heart"></i>
                        <h5>Bracelets</h5>
                    </div>
                </div>
                <div class="categories__item">
                    <div class="categories__item__icon">
                        <i class="fa-regular fa-star"></i>
                        <h5>Earrings</h5>
                    </div>
                </div>
                <div class="categories__item">
                    <div class="categories__item__icon">
                        <i class="fa-regular fa-clock"></i>
                        <h5>Watches</h5>
                    </div>
                </div>
                <div class="categories__item">
                    <div class="categories__item__icon">
                        <i class="fa-solid fa-layer-group"></i>
                        <h5>Collections</h5>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Categories Section End -->

<!-- Product Section Begin -->
<section class="product spad">
    <div class="container">
        <!-- Filter UI -->
        <div class="row mb-4">
            <div class="col-lg-12">
                <div class="filter__controls d-flex justify-content-center flex-wrap">
                    <a href="/collections?col=new" class="btn btn-outline-dark mx-2 mb-2">New Arrivals</a>
                    <a href="/collections?col=bestseller" class="btn btn-outline-dark mx-2 mb-2">Bestsellers</a>
                    <a href="/collections?col=sale" class="btn btn-outline-dark mx-2 mb-2">Best Prices</a>
                </div>
            </div>
        </div>

        <div class="row">

            {{#each plainProduct}}
                <div class="col-lg-3 col-md-6 col-sm-6">
                    <div class="product__item">
                        <div class="product__item__pic set-bg" data-setbg="{{image}}">
                            <div class="product__label">
                            </div>
                            <ul class="product__item__pic__hover">
                                <li>
                                    <a href="/wishlist/add/{{_id}}">
                                        <i class="fa fa-heart {{#if inWishlist}}heart-active{{/if}}"></i>
                                    </a>
                                </li>
                            </ul>
                            <a href="/product-detail/{{_id}}" class="w-100 h-100 d-block"></a>
                        </div>
                        <div class="product__item__text">
                            <h6>
                                <a href="/product-detail/{{_id}}">
                                    {{name}}
                                </a>
                            </h6>
                            <div class="product__item__price">
                                <span>{{formatCurrency price}} VND</span>
                            </div>
                            <div class="cart_add">
<!--                                <form action="/add-cart/{{_id}}" method="POST">-->
<!--                                    <button type="submit"-->
<!--                                            class="border-0 bg-transparent">-->
<!--                                        Add to cart-->
<!--                                    </button>-->
<!--                                </form>-->
                                <a href="/product-detail/{{this._id}}">Detail</a>
                            </div>
                        </div>
                    </div>
                </div>
            {{/each}}

        </div>

        {{#if isHome}}
            <div class="row mt-5">
                <div class="col-lg-12 text-center">
                    <a href="/jewelry" class="primary-btn">View More Products</a>
                </div>
            </div>
        {{/if}}
    </div>
</section>
<!-- Product Section End -->

<!-- Custom Jewelry Section Begin -->
<section class="class spad">

    <div class="container">
        <div class="custom__wrapper">
            <div class="custom__text">
                <span>Custom Jewelry</span>
                <h2>
                    Design Your <br>
                    Dream Jewelry
                </h2>
                <p>
                    Create personalized rings, necklaces and  accessories
                    crafted specially for your unique style and unforgettable moments.
                </p>
            </div>
            <div class="class__form">
                <form action="#">
                    <input type="text" placeholder="Your Name">
                    <input type="text" placeholder="Phone Number">
                    <select>
                        <option value="">Select Collection</option>
                        <option value="">Wedding Collection</option>
                        <option value="">Diamond Collection</option>
                        <option value="">Elegant Collection</option>
                    </select>
                    <textarea placeholder="Describe your custom design"></textarea>
                    <button type="submit" class="site-btn">
                        Send Request
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>


