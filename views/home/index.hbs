<!-- Hero Section Begin -->
<section class="hero">
    <div class="hero__slider owl-carousel">

        <div class="hero__item set-bg" data-setbg="img/hero/hero-1.jpg">

        </div>
    </div>
</section>
<!-- Hero Section End -->

<!-- About Section Begin -->
<section class="about spad">
    <div class="container">
        <div class="row">
            <div class="col-lg-6 col-md-6">
                <div class="about__text">
                    <div class="section-title">
                        <span>Giới thiệu cửa hàng trang sức</span>
                        <h2>Trang sức thanh lịch chế tác bằng niềm đam mê</h2>
                    </div>
                    <p>Khám phá các bộ sưu tập trang sức thanh lịch được thiết kế chính xác, đam mê và hiện đại. Mỗi sản phẩm đều phản chiếu vẻ đẹp, sự tự tin và tinh tế.</p>
                </div>
            </div>
            <div class="col-lg-6 col-md-6">
                <div class="about__bar">
                    <div class="about__bar__item">
                        <p>Thiết kế trang sức</p>
                        <div id="bar1" class="barfiller">
                            <div class="tipWrap"><span class="tip"></span></div>
                            <span class="fill" data-percentage="95"></span>
                        </div>
                    </div>
                    <div class="about__bar__item">
                        <p>Sự hài lòng của khách hàng</p>
                        <div id="bar2" class="barfiller">
                            <div class="tipWrap"><span class="tip"></span></div>
                            <span class="fill" data-percentage="80"></span>
                        </div>
                    </div>
                    <div class="about__bar__item">
                        <p>Bộ sưu tập thanh lịch</p>
                        <div id="bar3" class="barfiller">
                            <div class="tipWrap"><span class="tip"></span></div>
                            <span class="fill" data-percentage="90"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- About Section End -->

<!-- Categories Section Begin -->
<div class="categories">
    <div class="container">
        <div class="row">
            <div class="categories__slider owl-carousel">
                <div class="categories__item">
                    <div class="categories__item__icon">
                        <i class="fa-solid fa-diamond"></i>
                        <h5>Nhẫn</h5>
                    </div>
                </div>
                <div class="categories__item">
                    <div class="categories__item__icon">
                        <i class="fa-regular fa-gem"></i>
                        <h5>Dây chuyền</h5>
                    </div>
                </div>
                <div class="categories__item">
                    <div class="categories__item__icon">
                        <i class="fa-regular fa-heart"></i>
                        <h5>Vòng tay</h5>
                    </div>
                </div>
                <div class="categories__item">
                    <div class="categories__item__icon">
                        <i class="fa-regular fa-star"></i>
                        <h5>Bông tai</h5>
                    </div>
                </div>
                <div class="categories__item">
                    <div class="categories__item__icon">
                        <i class="fa-regular fa-clock"></i>
                        <h5>Đồng hồ</h5>
                    </div>
                </div>
                <div class="categories__item">
                    <div class="categories__item__icon">
                        <i class="fa-solid fa-layer-group"></i>
                        <h5>Bộ sưu tập</h5>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Categories Section End -->

<!-- Product Section Begin -->
<section class="product spad">
    <div class="container">
        <!-- Filter UI -->
        <div class="row mb-4">
            <div class="col-lg-12">
                <div class="filter__controls d-flex justify-content-center flex-wrap">
                    <a href="/collections?col=new" class="btn btn-outline-dark mx-2 mb-2">Hàng mới về</a>
                    <a href="/collections?col=bestseller" class="btn btn-outline-dark mx-2 mb-2">Bán chạy nhất</a>
                    <a href="/collections?col=sale" class="btn btn-outline-dark mx-2 mb-2">Giá tốt nhất</a>
                </div>
            </div>
        </div>

        <div class="row">

            {{#each plainProduct}}
                <div class="col-lg-3 col-md-6 col-sm-6">
                    <div class="product__item">
                        <div class="product__item__pic set-bg" data-setbg="{{image}}">
                            <div class="product__label">
                            </div>
                            <ul class="product__item__pic__hover">
                                <li>
                                    <a href="/wishlist/add/{{_id}}">
                                        <i class="fa fa-heart {{#if inWishlist}}heart-active{{/if}}"></i>
                                    </a>
                                </li>
                            </ul>
                            <a href="/product-detail/{{_id}}" class="w-100 h-100 d-block"></a>
                        </div>
                        <div class="product__item__text">
                            <h6>
                                <a href="/product-detail/{{_id}}">
                                    {{name}}
                                </a>
                            </h6>
                            <div class="product__item__price">
                                <span>{{formatCurrency price}} VND</span>
                            </div>
                            <div class="cart_add">
                                <a href="/product-detail/{{this._id}}">Chi tiết</a>
                            </div>
                        </div>
                    </div>
                </div>
            {{/each}}

        </div>

        {{#if isHome}}
            <div class="row mt-5">
                <div class="col-lg-12 text-center">
                    <a href="/jewelry" class="primary-btn">Xem thêm sản phẩm</a>
                </div>
            </div>
        {{/if}}
    </div>
</section>
<!-- Product Section End -->

<!-- Custom Jewelry Section Begin -->
<section class="class spad">

    <div class="container">
        <div class="custom__wrapper">
            <div class="custom__text">
                <span>Trang sức thiết kế</span>
                <h2>
                    Thiết kế <br>
                    trang sức mơ ước
                </h2>
                <p>
                    Tạo các mẫu nhẫn, dây chuyền và phụ kiện cá nhân hóa được chế tác dành riêng cho phong cách độc đáo và những khoảnh khắc đáng nhớ.
                </p>
            </div>
            <div class="class__form">
                <form action="#">
                    <input type="text" placeholder="Họ và tên">
                    <input type="text" placeholder="Số điện thoại">
                    <select>
                        <option value="">Chọn bộ sưu tập</option>
                        <option value="">Bộ sưu tập Ngày cưới</option>
                        <option value="">Bộ sưu tập Kim cương</option>
                        <option value="">Bộ sưu tập Sang trọng</option>
                    </select>
                    <textarea placeholder="Mô tả ý tưởng thiết kế"></textarea>
                    <button type="submit" class="site-btn">
                        Gửi yêu cầu
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>


